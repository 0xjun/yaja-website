---
/**
 * Pure-CSS iPhone-style mockup for showcasing TikTok/Instagram screens.
 * Render the actual screenshot inside via the default slot.
 *
 * Sizes itself responsively. Default aspect 9:19.5 (iPhone 15 Pro).
 */
---

<div class="phone-frame relative shrink-0 select-none">
  <div
    class="relative overflow-hidden rounded-[2.4rem] border border-white/10 bg-yaja-charcoal shadow-[0_20px_60px_-20px_rgba(255,72,72,0.4),0_30px_120px_-40px_rgba(0,0,0,0.8)]"
    style="aspect-ratio: 9 / 19.5;"
  >
    <!-- Notch -->
    <div
      class="absolute left-1/2 top-2.5 z-20 flex h-6 w-24 -translate-x-1/2 items-center justify-center rounded-full bg-black"
      aria-hidden="true"
    >
    </div>

    <!-- Screen content -->
    <div class="relative h-full w-full">
      <slot />
    </div>

    <!-- Inner reflection -->
    <div
      class="pointer-events-none absolute inset-0 rounded-[2.4rem] bg-gradient-to-br from-white/[0.03] via-transparent to-white/[0.05]"
      aria-hidden="true"
    >
    </div>
  </div>
</div>
