---
/**
 * Vertical-video slot (9:16) for the OASIZ-style PROJECTS cards.
 *
 * - If a `src` is provided, plays the video on loop (muted, autoplay).
 * - Otherwise renders a styled placeholder so the layout is complete
 *   immediately. When the user uploads an actual MP4 to /public/videos/,
 *   simply set the `src` prop in site.ts and the placeholder disappears.
 */
interface Props {
  src?: string;
  poster?: string;
  brand?: string;
  className?: string;
}
const { src, poster, brand = "YAJA", className = "" } = Astro.props;
---

<div
  class:list={[
    "relative aspect-[9/16] overflow-hidden rounded-lg ring-1 ring-white/10",
    className,
  ]}
>
  {
    src ? (
      <video
        src={src}
        poster={poster}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        class="h-full w-full object-cover"
      />
    ) : (
      <>
        {/* Placeholder — moody gradient + brand watermark + faux-play */}
        <div class="absolute inset-0 bg-gradient-to-br from-yaja-charcoal via-black to-yaja-dark" />
        <div
          class="absolute inset-0 opacity-[0.07]"
          style="background-image: linear-gradient(135deg, transparent 49.5%, white 49.5% 50.5%, transparent 50.5%); background-size: 16px 16px;"
        />
        <img
          src="/logos/fire-symbol/red-symbol.png"
          alt=""
          aria-hidden="true"
          class="absolute left-1/2 top-1/2 h-1/3 w-auto -translate-x-1/2 -translate-y-1/2 opacity-30 anim-flame-breathe"
        />
        <span class="absolute bottom-3 left-3 right-3 font-num text-[9px] uppercase tracking-[0.2em] text-yaja-gray-mid">
          {brand} · Coming soon
        </span>
        {/* Vignette */}
        <div
          class="absolute inset-0"
          style="background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.5) 100%);"
        />
      </>
    )
  }
</div>
