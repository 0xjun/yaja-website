---
import { hero, stats } from "@/lib/site";
import DramaGrid from "@/components/DramaGrid.astro";
---

<section
  class="relative isolate flex min-h-[100svh] flex-col justify-between overflow-hidden bg-yaja-dark"
  aria-label="Hero"
>
  <!-- Tilted drama frame grid (DESIGN.md cover aesthetic) -->
  <DramaGrid />

  <!-- Ambient red glow over the grid -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute -left-[15%] top-[15%] h-[55vh] w-[55vh] rounded-full bg-yaja-red/20 blur-[140px] anim-fade-in-slow"
    >
    </div>
    <div
      class="absolute -right-[10%] bottom-[10%] h-[45vh] w-[45vh] rounded-full bg-yaja-red/15 blur-[140px] anim-fade-in-slow"
      style="animation-delay: 0.4s"
    >
    </div>
  </div>

  <!-- ========== TOP CONTENT ========== -->
  <div
    class="relative mx-auto flex w-full max-w-[1440px] flex-col px-6 pt-32 md:px-10 md:pt-40"
  >
    <!-- Eyebrow -->
    <p
      class="anim-fade-in flex items-center gap-3 font-num text-[10px] font-semibold uppercase tracking-[0.22em] text-yaja-red md:text-[11px]"
      style="animation-delay: 0.1s"
    >
      <span class="block h-px w-8 bg-yaja-red"></span>
      {hero.eyebrow}
    </p>

    <!-- Headline — 4 lines, character-revealed -->
    <h1
      class="hero-title mt-8 font-black leading-[0.92] tracking-[-0.025em]"
      style="font-size: clamp(48px, 13vw, 200px);"
    >
      <span
        class="reveal-word block"
        style="animation: hero-line 1s cubic-bezier(0.16,1,0.3,1) 0.3s both;"
      >
        {hero.headline[0]}
      </span>
      <span
        class="reveal-word block text-yaja-red"
        style="animation: hero-line 1s cubic-bezier(0.16,1,0.3,1) 0.45s both;"
      >
        {hero.headline[1]}
      </span>
      <span
        class="reveal-word block"
        style="animation: hero-line 1s cubic-bezier(0.16,1,0.3,1) 0.6s both;"
      >
        {hero.headline[2]}
      </span>
      <span
        class="reveal-word block"
        style="animation: hero-line 1s cubic-bezier(0.16,1,0.3,1) 0.75s both;"
      >
        {hero.headline[3]}
      </span>
    </h1>
  </div>

  <!-- ========== BOTTOM CONTENT ========== -->
  <div
    class="relative mx-auto flex w-full max-w-[1440px] flex-col gap-12 px-6 pb-20 pt-20 md:flex-row md:items-end md:justify-between md:px-10 md:pb-16"
  >
    <!-- Subhead + CTAs -->
    <div class="max-w-[42ch]">
      <p
        class="anim-fade-in text-base text-yaja-gray md:text-xl"
        style="animation-delay: 1s"
      >
        {hero.subhead}
      </p>

      <div
        class="anim-fade-in mt-8 flex flex-wrap gap-3"
        style="animation-delay: 1.2s"
      >
        <a
          href="#works"
          class="group/cta relative overflow-hidden rounded-md bg-yaja-red px-7 py-4 font-num text-[12px] font-bold tracking-[0.12em] text-yaja-white transition-transform hover:-translate-y-0.5"
        >
          <span class="relative z-10">SEE WORKS →</span>
          <span
            class="absolute inset-0 -translate-x-full bg-white/20 transition-transform duration-500 group-hover/cta:translate-x-0"
          ></span>
        </a>
        <a
          href="#contact"
          class="rounded-md border border-white/20 px-7 py-4 font-num text-[12px] font-bold tracking-[0.12em] text-yaja-white transition-colors hover:border-yaja-red hover:text-yaja-red"
        >
          문의하기
        </a>
      </div>
    </div>

    <!-- Mini stats teaser (sneak-peek of #overview) -->
    <div
      class="anim-fade-in grid grid-cols-3 gap-6 md:gap-12"
      style="animation-delay: 1.5s"
    >
      {
        stats.slice(0, 3).map((s) => (
          <div>
            <p class="font-num text-2xl font-black leading-none tracking-tight md:text-4xl">
              {s.value}
            </p>
            <p class="font-num mt-2 text-[9px] uppercase tracking-[0.18em] text-yaja-gray-mid md:text-[10px]">
              {s.label}
            </p>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Bottom hairline + scroll cue -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0">
    <div
      class="anim-fade-in flex justify-center pb-3"
      style="animation-delay: 1.8s"
    >
      <span
        class="font-num flex items-center gap-2 text-[9px] font-semibold uppercase tracking-[0.22em] text-yaja-gray-mid"
      >
        Scroll <span class="block h-px w-8 animate-pulse bg-current"></span>
      </span>
    </div>
  </div>
</section>

<style>
  @keyframes hero-line {
    from {
      opacity: 0;
      transform: translateY(40%);
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .hero-title .reveal-word {
    display: block;
    overflow: hidden;
  }
</style>
