---
import { founders } from "@/lib/site";
---

<section
  id="about"
  class="bg-yaja-dark py-24 md:py-32"
  aria-label="Founders"
>
  <div class="mx-auto max-w-[1440px] px-6 md:px-10">
    <div class="reveal">
      <p
        class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-red"
      >
        About
      </p>
      <h2 class="mt-4 max-w-[28ch] text-3xl font-extrabold leading-tight md:text-5xl">
        창업 멤버
      </h2>
      <p class="mt-5 max-w-[52ch] text-yaja-gray-mid md:text-lg">
        한국 최고의 크리에이터와 프로듀서가 모여 2024년 YAJA Inc.를
        설립했습니다.
      </p>
    </div>

    <div
      class="reveal reveal-stagger mt-12 grid gap-10 md:mt-16 md:grid-cols-3"
    >
      {
        founders.map((founder) => (
          <article class="rounded-lg border border-white/10 bg-white/[0.02] p-8 transition-colors hover:border-yaja-red/40">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-yaja-red/10 ring-1 ring-yaja-red/30">
              <span class="font-num text-lg font-extrabold text-yaja-red">
                {founder.name.split(" ").map((n) => n[0]).join("")}
              </span>
            </div>
            <h3 class="font-num mt-6 text-xl font-extrabold tracking-tight md:text-2xl">
              {founder.name}
            </h3>
            <p class="font-num text-sm text-yaja-red">{founder.role}</p>
            <p class="mt-5 text-sm leading-relaxed text-yaja-gray-mid md:text-base">
              {founder.bio}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
