---
import { clients } from "@/lib/site";

/**
 * OASIZ §7 mirror — static client grid (3×3).
 * No marquee; minimalist tiled layout reflects OASIZ's restrained aesthetic.
 */
---

<section
  id="clients"
  class="relative border-t border-white/8 bg-yaja-dark py-24 md:py-32"
  aria-label="Clients"
>
  <div class="mx-auto max-w-[1280px] px-6 md:px-10">
    <p
      class="reveal font-num text-center text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red"
    >
      Clients
    </p>
    <h2
      class="reveal mx-auto mt-6 max-w-[24ch] text-center font-black leading-[1.1] tracking-[-0.02em] md:mt-8"
      style="font-size: clamp(32px, 5vw, 72px);"
    >
      함께한 <span class="text-yaja-red">브랜드</span>
    </h2>

    <div
      class="reveal reveal-stagger mx-auto mt-16 grid max-w-[960px] grid-cols-3 gap-px overflow-hidden rounded-lg border border-white/10 bg-white/10 md:mt-20"
    >
      {
        clients.map((c) => (
          <div class="group flex aspect-[4/3] items-center justify-center bg-yaja-dark p-6 transition-colors hover:bg-yaja-charcoal">
            <span class="font-num text-center text-sm font-bold tracking-tight text-yaja-white/90 transition-colors group-hover:text-yaja-red md:text-base lg:text-lg">
              {c}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
