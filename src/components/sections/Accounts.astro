---
import { accounts } from "@/lib/site";
---

<section
  id="accounts"
  class="bg-yaja-dark py-24 md:py-32"
  aria-label="Owned channels"
>
  <div class="mx-auto max-w-[1440px] px-6 md:px-10">
    <div class="reveal">
      <p
        class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-red"
      >
        02 — Channels
      </p>
      <h2 class="mt-4 max-w-[28ch] text-3xl font-extrabold leading-tight md:text-5xl">
        자체 운영 채널
      </h2>
      <p class="mt-5 max-w-[48ch] text-yaja-gray-mid md:text-lg">
        기획·제작·운영을 모두 자체적으로 수행하는 K-Short Drama 채널입니다.
      </p>
    </div>

    <div
      class="reveal reveal-stagger mt-12 grid gap-6 md:mt-16 md:grid-cols-2 md:gap-10"
    >
      {
        accounts.map((account) => (
          <a
            href={account.href}
            target="_blank"
            rel="noopener"
            class="group relative block overflow-hidden rounded-lg border border-white/10 bg-gradient-to-b from-white/[0.04] to-transparent p-8 transition-all hover:border-yaja-red md:p-10"
          >
            <div class="flex items-baseline justify-between gap-4">
              <div>
                <p class="font-num text-[10px] font-semibold uppercase tracking-[0.16em] text-yaja-gray">
                  {account.subtitle}
                </p>
                <h3 class="font-num mt-1 text-3xl font-extrabold tracking-tight md:text-4xl">
                  {account.title}
                </h3>
              </div>
              <p class="font-num text-sm text-yaja-gray-mid">
                {account.handle}
              </p>
            </div>

            <dl class="mt-10 grid grid-cols-3 gap-6 border-t border-white/10 pt-8">
              <div>
                <dt class="font-num text-[10px] font-semibold uppercase tracking-[0.14em] text-yaja-gray">
                  누적 조회수
                </dt>
                <dd class="font-num mt-2 text-3xl font-black tracking-tight md:text-4xl">
                  {account.cumulativeViews}
                  <span class="ml-1 text-sm text-yaja-gray-mid">회</span>
                </dd>
              </div>
              <div>
                <dt class="font-num text-[10px] font-semibold uppercase tracking-[0.14em] text-yaja-gray">
                  팔로워
                </dt>
                <dd class="font-num mt-2 text-3xl font-black tracking-tight md:text-4xl">
                  {account.followers}
                  <span class="ml-1 text-sm text-yaja-gray-mid">명</span>
                </dd>
              </div>
              <div>
                <dt class="font-num text-[10px] font-semibold uppercase tracking-[0.14em] text-yaja-gray">
                  평균 조회수
                </dt>
                <dd class="font-num mt-2 text-xl font-black tracking-tight md:text-2xl">
                  {account.avgViews}
                </dd>
              </div>
            </dl>

            <span
              class="font-num pointer-events-none absolute right-8 top-8 text-[10px] font-semibold uppercase tracking-[0.16em] text-yaja-gray opacity-0 transition-opacity group-hover:text-yaja-red group-hover:opacity-100"
            >
              View →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
