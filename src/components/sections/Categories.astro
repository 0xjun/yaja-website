---
import { categories } from "@/lib/site";

/**
 * OASIZ §4 mirror — bilingual category list with ★ icons,
 * stacked vertically with subtle hover. Each row reveals on scroll.
 */
---

<section
  id="services"
  class="relative border-t border-white/8 bg-yaja-dark py-24 md:py-32"
  aria-label="Categories"
>
  <div class="mx-auto max-w-[1280px] px-6 md:px-10">
    <p
      class="reveal font-num text-center text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red"
    >
      Categories
    </p>
    <h2
      class="reveal mx-auto mt-6 max-w-[24ch] text-center font-black leading-[1.1] tracking-[-0.02em] md:mt-8"
      style="font-size: clamp(32px, 5vw, 72px);"
    >
      쇼트드라마를 통한 <span class="text-yaja-red">5가지 솔루션</span>
    </h2>

    <ul
      class="reveal reveal-stagger mt-16 divide-y divide-white/10 border-y border-white/10 md:mt-20"
    >
      {
        categories.map((cat) => (
          <li class="group">
            <a
              href="#contact"
              class="grid grid-cols-[auto_1fr_auto] items-center gap-6 py-7 transition-colors hover:bg-white/[0.02] md:grid-cols-[auto_120px_1fr_auto] md:gap-10 md:py-10"
            >
              <span
                class="font-num text-base font-extrabold tracking-tight text-yaja-red md:text-2xl"
                aria-hidden="true"
              >
                ★
              </span>
              <span class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-gray-mid">
                {cat.no}
              </span>
              <div>
                <h3
                  class="font-extrabold tracking-[-0.015em] transition-transform duration-500 group-hover:translate-x-1"
                  style="font-size: clamp(20px, 2.6vw, 36px);"
                >
                  {cat.ko}
                  <span class="ml-3 font-num text-base font-medium text-yaja-gray md:ml-5 md:text-xl">
                    / {cat.en}
                  </span>
                </h3>
                <p class="mt-2 hidden max-w-[60ch] text-sm text-yaja-gray-mid md:block md:text-base">
                  {cat.description}
                </p>
              </div>
              <span
                class="font-num text-yaja-gray-mid transition-colors group-hover:text-yaja-red"
                aria-hidden="true"
              >
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
