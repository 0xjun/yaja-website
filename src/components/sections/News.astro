---
import { news } from "@/lib/site";

/**
 * OASIZ §10 mirror — news list (date + category + title rows).
 */
---

<section
  id="news"
  class="relative border-t border-white/8 bg-yaja-dark py-24 md:py-32"
  aria-label="News"
>
  <div class="mx-auto max-w-[1280px] px-6 md:px-10">
    <div class="reveal flex items-end justify-between">
      <div>
        <p class="font-num text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red">
          News
        </p>
        <h2
          class="mt-4 font-black tracking-[-0.02em]"
          style="font-size: clamp(28px, 4vw, 52px);"
        >
          최신 소식
        </h2>
      </div>

      <a
        href="#"
        class="font-num hidden items-center gap-2 text-[11px] font-semibold tracking-[0.18em] text-yaja-gray transition-colors hover:text-yaja-red md:inline-flex"
      >
        ALL
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <ul class="reveal reveal-stagger mt-12 divide-y divide-white/10 border-y border-white/10 md:mt-16">
      {
        news.map((n) => (
          <li>
            <a
              href="#"
              class="group grid grid-cols-[120px_1fr_auto] items-center gap-6 py-6 transition-colors hover:bg-white/[0.02] md:grid-cols-[140px_140px_1fr_auto] md:gap-10 md:py-8"
            >
              <span class="font-num text-sm text-yaja-gray-mid md:text-base">
                {n.date}
              </span>
              <span class="font-num hidden rounded-full border border-yaja-red/40 px-3 py-1 text-center text-[10px] font-semibold uppercase tracking-[0.12em] text-yaja-red md:inline-block md:w-fit">
                {n.category}
              </span>
              <span class="font-num text-base font-medium leading-snug transition-colors group-hover:text-yaja-red md:text-lg">
                {n.title}
              </span>
              <span
                class="font-num text-yaja-gray-mid transition-colors group-hover:text-yaja-red"
                aria-hidden="true"
              >
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
