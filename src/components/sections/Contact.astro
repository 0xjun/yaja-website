---
import { site } from "@/lib/site";
---

<section
  id="contact"
  class="relative overflow-hidden bg-yaja-dark py-32 md:py-56"
  aria-label="Contact"
>
  <!-- Massive ambient red glow -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute left-1/2 top-1/2 h-[100vh] w-[100vh] -translate-x-1/2 -translate-y-1/2 rounded-full bg-yaja-red/20 blur-[160px]"
    >
    </div>
    <!-- Diagonal grid texture -->
    <div
      class="absolute inset-0 opacity-[0.06]"
      style="background-image: linear-gradient(135deg, transparent 49.5%, white 49.5% 50.5%, transparent 50.5%); background-size: 32px 32px;"
    >
    </div>
  </div>

  <div class="mx-auto max-w-[1600px] px-6 text-center md:px-10">
    <p
      class="reveal font-num inline-flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-yaja-red"
    >
      <span class="block h-px w-8 bg-yaja-red"></span>
      Contact
      <span class="block h-px w-8 bg-yaja-red"></span>
    </p>

    <h2
      class="reveal mx-auto mt-8 max-w-[20ch] font-black leading-[0.92] tracking-[-0.025em]"
      style="font-size: clamp(48px, 9vw, 168px);"
    >
      함께
      <span class="text-yaja-red">새로운 IP</span>를<br />
      만들어 보세요.
    </h2>

    <p class="reveal mx-auto mt-10 max-w-[44ch] text-yaja-gray-mid md:text-xl">
      브랜드 캠페인부터 자체 IP 협업까지, 어떤 단계에 계시든<br
        class="hidden md:block"
      />가장 효과적인 방법을 함께 설계합니다.
    </p>

    <div class="reveal mt-16 flex flex-wrap items-center justify-center gap-3">
      <a
        href={`mailto:${site.email}`}
        class="group/cta relative overflow-hidden rounded-md bg-yaja-red px-9 py-5 font-num text-sm font-bold tracking-[0.1em] text-yaja-white transition-transform hover:-translate-y-0.5"
      >
        <span class="relative z-10">{site.email}</span>
        <span
          class="absolute inset-0 -translate-x-full bg-white/20 transition-transform duration-500 group-hover/cta:translate-x-0"
        ></span>
      </a>
      <a
        href="https://www.tiktok.com/@yajacamp"
        target="_blank"
        rel="noopener"
        class="rounded-md border border-white/20 px-9 py-5 font-num text-sm font-bold tracking-[0.1em] text-yaja-white transition-colors hover:border-yaja-red hover:text-yaja-red"
      >
        @yajacamp 보기
      </a>
    </div>
  </div>
</section>
