---
import { services } from "@/lib/site";
---

<section
  id="services"
  class="relative bg-yaja-dark py-24 md:py-32"
  aria-label="Services"
>
  <div class="mx-auto max-w-[1440px] px-6 md:px-10">
    <div class="reveal">
      <p
        class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-red"
      >
        03 — Services
      </p>
      <h2 class="mt-4 max-w-[28ch] text-3xl font-extrabold leading-tight md:text-5xl">
        4가지 솔루션
      </h2>
      <p class="mt-5 max-w-[52ch] text-yaja-gray-mid md:text-lg">
        브랜드의 단계와 목적에 맞춰 서비스를 조합합니다. 단발성 PPL부터
        오리지널 IP까지, YAJA 한 곳에서 해결합니다.
      </p>
    </div>

    <div
      class="reveal reveal-stagger mt-12 grid gap-px overflow-hidden rounded-lg border border-white/10 bg-white/10 md:mt-16 md:grid-cols-2"
    >
      {
        services.map((service, i) => (
          <article class="bg-yaja-dark p-8 transition-colors hover:bg-yaja-charcoal md:p-12">
            <p class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-red">
              {String(i + 1).padStart(2, "0")}
            </p>
            <h3 class="font-num mt-3 text-2xl font-extrabold tracking-tight md:text-3xl">
              {service.title}
            </h3>
            <p class="mt-2 text-sm text-yaja-gray md:text-base">
              {service.subtitle}
            </p>
            <p class="mt-6 max-w-[40ch] text-sm text-yaja-gray-mid md:text-base">
              {service.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
