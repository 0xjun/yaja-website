---
import { projects } from "@/lib/site";

/**
 * OASIZ §5 mirror — rich case-study cards (1 column wide,
 * each row: brand + title + tags + description + metric).
 */
---

<section
  id="works"
  class="relative bg-yaja-dark py-24 md:py-32"
  aria-label="Projects"
>
  <div class="mx-auto max-w-[1280px] px-6 md:px-10">
    <p
      class="reveal font-num text-center text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red"
    >
      Projects
    </p>
    <h2
      class="reveal mx-auto mt-6 max-w-[24ch] text-center font-black leading-[1.1] tracking-[-0.02em] md:mt-8"
      style="font-size: clamp(32px, 5vw, 72px);"
    >
      검증된 <span class="text-yaja-red">성과</span>
    </h2>

    <div class="reveal reveal-stagger mt-16 grid gap-6 md:mt-20 md:grid-cols-2 md:gap-8">
      {
        projects.map((p) => (
          <article class="group relative flex flex-col overflow-hidden rounded-lg border border-white/10 bg-gradient-to-b from-white/[0.03] to-transparent p-8 transition-colors hover:border-yaja-red/40 md:p-10">
            {/* Top: brand + handle */}
            <div class="flex items-center justify-between">
              <p class="font-num text-2xl font-black tracking-tight md:text-3xl">
                {p.brand}
              </p>
              <span class="font-num text-xs text-yaja-gray-mid md:text-sm">
                {p.handle}
              </span>
            </div>

            <p class="font-num mt-2 text-[11px] uppercase tracking-[0.18em] text-yaja-red">
              {p.type}
            </p>

            {/* Title */}
            <h3 class="mt-6 text-lg font-bold leading-snug md:text-xl">
              {p.title}
            </h3>

            {/* Description */}
            <p class="mt-4 flex-1 text-sm leading-relaxed text-yaja-gray-mid md:text-base">
              {p.description}
            </p>

            {/* Tags */}
            <ul class="mt-6 flex flex-wrap gap-2">
              {p.tags.map((tag) => (
                <li class="font-num rounded-full border border-white/15 px-3 py-1 text-[10px] uppercase tracking-[0.12em] text-yaja-gray">
                  {tag}
                </li>
              ))}
            </ul>

            {/* Metric */}
            <div class="mt-8 border-t border-white/10 pt-6">
              <p class="font-num text-[10px] uppercase tracking-[0.18em] text-yaja-gray">
                {p.metric.label}
              </p>
              <p class="font-num mt-2 text-3xl font-black tracking-tight md:text-4xl">
                {p.metric.value}
                <span class="ml-1 text-base font-bold text-yaja-gray-mid">
                  {p.metric.unit}
                </span>
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
