---
import VerticalVideo from "@/components/VerticalVideo.astro";
import { projects } from "@/lib/site";

/**
 * OASIZ §5 mirror — rich case-study cards with vertical (9:16) video
 * slot on the left, content on the right. Until a real MP4 is provided,
 * the slot renders a moody placeholder.
 */
---

<section
  id="works"
  class="relative bg-yaja-dark py-24 md:py-32"
  aria-label="Projects"
>
  <div class="mx-auto max-w-[1280px] px-6 md:px-10">
    <p
      class="reveal font-num text-center text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red"
    >
      Projects
    </p>
    <h2
      class="reveal mx-auto mt-6 max-w-[24ch] text-center font-black leading-[1.1] tracking-[-0.02em] md:mt-8"
      style="font-size: clamp(32px, 5vw, 72px);"
    >
      검증된 <span class="text-yaja-red">성과</span>
    </h2>

    <div class="reveal reveal-stagger mt-16 space-y-16 md:mt-24 md:space-y-24">
      {
        projects.map((p) => (
          <article class="group grid items-center gap-8 md:grid-cols-[280px_1fr] md:gap-14 lg:grid-cols-[320px_1fr]">
            {/* Vertical video slot (9:16) — fixed width on md+ for
                consistent sizing across all cards. */}
            <VerticalVideo
              src={p.video || undefined}
              brand={p.brand}
              className="mx-auto w-full max-w-[260px] md:mx-0 md:max-w-[280px] lg:max-w-[320px]"
            />

            {/* Content */}
            <div>
              <p class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-red">
                {p.type}
              </p>
              <p
                class="font-num mt-3 font-black tracking-[-0.025em]"
                style="font-size: clamp(28px, 3.6vw, 56px);"
              >
                {p.brand}
              </p>
              <p class="font-num mt-1 text-sm text-yaja-gray-mid md:text-base">
                {p.handle}
              </p>

              <h3 class="mt-6 max-w-[44ch] text-lg font-bold leading-snug md:text-2xl">
                {p.title}
              </h3>
              <p class="mt-4 max-w-[60ch] text-sm leading-relaxed text-yaja-gray-mid md:text-base">
                {p.description}
              </p>

              <ul class="mt-6 flex flex-wrap gap-2">
                {p.tags.map((tag) => (
                  <li class="font-num rounded-full border border-white/15 px-3 py-1 text-[10px] uppercase tracking-[0.12em] text-yaja-gray">
                    {tag}
                  </li>
                ))}
              </ul>

              <div class="mt-8 flex items-baseline gap-3 border-t border-white/10 pt-6">
                <span class="font-num text-[10px] uppercase tracking-[0.18em] text-yaja-gray">
                  {p.metric.label}
                </span>
                <span class="font-num text-3xl font-black tracking-tight md:text-5xl">
                  {p.metric.value}
                  <span class="ml-1 text-base font-bold text-yaja-gray-mid">
                    {p.metric.unit}
                  </span>
                </span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
