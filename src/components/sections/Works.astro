---
import { works } from "@/lib/site";
---

<section
  id="works"
  class="relative overflow-hidden bg-yaja-dark py-24 md:py-40"
  aria-label="Selected works"
>
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <div class="reveal flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p
          class="font-num flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-yaja-red"
        >
          <span class="block h-px w-8 bg-yaja-red"></span>
          04 — Works
        </p>
        <h2
          class="mt-6 max-w-[24ch] font-black leading-[0.95] tracking-[-0.02em]"
          style="font-size: clamp(36px, 6vw, 96px);"
        >
          검증된 <span class="text-yaja-red">성과</span>
        </h2>
      </div>
      <p class="max-w-[40ch] text-yaja-gray-mid md:text-right md:text-lg">
        글로벌 브랜드와의 협업 사례. 모든 캠페인은<br
          class="hidden md:block"
        />기획부터 운영까지 YAJA가 책임집니다.
      </p>
    </div>

    <!-- Case study cards: full-bleed rows with hover-glow -->
    <div class="reveal mt-16 md:mt-24">
      <ul class="divide-y divide-white/10 border-y border-white/10">
        {
          works.map((work, i) => (
            <li class="group relative">
              <a
                href="#contact"
                class="grid grid-cols-1 gap-3 py-10 transition-colors hover:bg-white/[0.02] md:grid-cols-12 md:items-baseline md:gap-6 md:py-14"
              >
                {/* Index */}
                <div class="md:col-span-1">
                  <span class="font-num text-[10px] font-semibold uppercase tracking-[0.18em] text-yaja-gray">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                </div>

                {/* Brand name */}
                <div class="md:col-span-3">
                  <p
                    class="font-num font-black tracking-[-0.025em] transition-transform duration-500 group-hover:translate-x-2 group-hover:text-yaja-red"
                    style="font-size: clamp(28px, 3vw, 56px);"
                  >
                    {work.brand}
                  </p>
                </div>

                {/* Service type */}
                <div class="md:col-span-3">
                  <p class="text-base text-yaja-white/90 md:text-lg">
                    {work.type}
                  </p>
                  <p class="font-num mt-1 text-[10px] uppercase tracking-[0.16em] text-yaja-gray">
                    {work.detail}
                  </p>
                </div>

                {/* Account handle */}
                <div class="md:col-span-2">
                  <p class="font-num text-sm text-yaja-gray">
                    {work.handle}
                  </p>
                </div>

                {/* Views — large */}
                <div class="md:col-span-3 md:text-right">
                  <p
                    class="font-num font-black tracking-[-0.025em]"
                    style="font-size: clamp(28px, 3vw, 56px);"
                  >
                    {work.views}
                    <span class="ml-1 text-xs font-bold text-yaja-gray-mid md:text-base">
                      회
                    </span>
                  </p>
                  <p class="font-num text-[9px] uppercase tracking-[0.18em] text-yaja-gray md:text-right">
                    Total Views
                  </p>
                </div>
              </a>

              {/* Hover red sliver */}
              <span
                class="pointer-events-none absolute left-0 top-0 h-full w-px origin-top scale-y-0 bg-yaja-red transition-transform duration-500 group-hover:scale-y-100"
                aria-hidden="true"
              />
            </li>
          ))
        }
      </ul>
    </div>

    <p class="font-num mt-10 text-center text-[11px] uppercase tracking-[0.22em] text-yaja-gray-mid">
      ↓ 더 많은 사례는 문의 시 안내드립니다
    </p>
  </div>
</section>
