---
import CountUp from "@/components/CountUp";
import { heroStats } from "@/lib/site";

/**
 * OASIZ §2 mirror — two prominent stats (left/right).
 * Each card: small description above, mega number, unit, footer note.
 */
---

<section
  id="overview"
  class="relative border-y border-white/8 bg-yaja-dark py-24 md:py-32"
  aria-label="Numbers"
>
  <div class="mx-auto max-w-[1280px] px-6 md:px-10">
    <p class="reveal font-num text-center text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red">
      Numbers
    </p>

    <div class="reveal reveal-stagger mt-16 grid gap-12 md:mt-24 md:grid-cols-2 md:gap-px md:overflow-hidden md:rounded-lg md:border md:border-white/10 md:bg-white/10">
      {
        heroStats.primary.map((stat) => (
          <div class="bg-yaja-dark p-2 text-center md:p-12 lg:p-16">
            <p class="text-sm text-yaja-gray-mid md:text-base">{stat.label}</p>

            <div class="mt-6 flex items-baseline justify-center gap-2 md:mt-10">
              <span
                class="font-num font-black leading-none tracking-[-0.04em] text-yaja-white"
                style="font-size: clamp(96px, 14vw, 200px);"
              >
                <CountUp client:visible to={stat.value} />
              </span>
              <span
                class="font-num font-extrabold tracking-[-0.02em] text-yaja-red"
                style="font-size: clamp(28px, 4vw, 56px);"
              >
                {stat.unit}
              </span>
            </div>

            <p class="font-num mt-6 text-[11px] uppercase tracking-[0.18em] text-yaja-gray md:mt-10">
              <span class="text-yaja-red">★</span>
              <span class="ml-2">{stat.note}</span>
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
