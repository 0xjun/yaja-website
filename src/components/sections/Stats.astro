---
import CountUp from "@/components/CountUp";
import { stats } from "@/lib/site";
---

<section
  id="overview"
  class="relative border-y border-white/5 bg-yaja-dark py-24 md:py-32"
  aria-label="Overview stats"
>
  <div class="mx-auto max-w-[1440px] px-6 md:px-10">
    <div class="reveal">
      <p
        class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-red"
      >
        01 — Overview
      </p>
      <h2 class="mt-4 max-w-[24ch] text-3xl font-extrabold leading-tight md:text-5xl">
        숫자로 증명하는<br />
        <span class="text-yaja-red">대한민국 No.1</span>
      </h2>
    </div>

    <div
      class="reveal reveal-stagger mt-14 grid grid-cols-2 gap-x-6 gap-y-12 md:mt-20 md:grid-cols-4 md:gap-x-10"
    >
      {
        stats.map((stat) => (
          <div class="border-l-2 border-yaja-red pl-5 md:pl-7">
            <p class="font-num text-[10px] font-semibold uppercase tracking-[0.14em] text-yaja-gray">
              {stat.label}
            </p>
            <p class="font-num mt-3 text-5xl font-black leading-none tracking-tight md:text-7xl lg:text-[88px]">
              <CountUp
                client:visible
                to={stat.numeric}
                suffix={stat.unit}
              />
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
