---
/**
 * Header — OASIZ-style flat nav (ABOUT / PROJECTS / COLUMN / NEWS /
 * CONTACT). Transparent over hero, blurred dark on scroll past 40px.
 */
const navItems = [
  { label: "ABOUT", href: "/about" },
  { label: "PROJECTS", href: "/projects" },
  { label: "COLUMN", href: "/column" },
  { label: "NEWS", href: "/news" },
  { label: "CONTACT", href: "/contact" },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-header
>
  <div
    class="mx-auto flex max-w-[1440px] items-center justify-between px-6 py-5 md:px-10 md:py-6"
  >
    <!-- Logo lockup — official combined logo (flame + handlettered
         "yaja"). DESIGN.md §3.1 requires the official wordmark. -->
    <a
      href="/"
      class="group inline-flex items-center"
      aria-label="YAJA Inc."
    >
      <img
        src="/logos/yaja-symbol/red-symbol.png"
        alt="YAJA"
        width="829"
        height="443"
        class="h-7 w-auto transition-transform group-hover:scale-[1.04] md:h-8"
      />
    </a>

    <!-- Center nav (OASIZ uses center-spaced primary nav) -->
    <nav class="hidden items-center gap-10 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="font-num group/link relative text-[11px] font-semibold tracking-[0.18em] text-yaja-white/80 transition-colors hover:text-yaja-white"
          >
            {item.label}
            <span
              class="absolute -bottom-1 left-0 block h-px w-full origin-left scale-x-0 bg-yaja-red transition-transform duration-500 group-hover/link:scale-x-100"
              aria-hidden="true"
            />
          </a>
        ))
      }
    </nav>

    <!-- Right cluster (lang + CTA) -->
    <div class="flex items-center gap-4">
      <span
        class="font-num hidden text-[11px] font-semibold tracking-[0.18em] text-yaja-white/60 md:inline-flex md:items-center md:gap-2"
      >
        <span class="text-yaja-red">KO</span>
        <span class="block h-3 w-px bg-white/20"></span>
        <span class="cursor-not-allowed line-through opacity-50" title="Coming soon">EN</span>
      </span>

      <a
        href="/contact"
        class="font-num hidden rounded-md border border-yaja-red bg-yaja-red px-5 py-2.5 text-[11px] font-bold tracking-[0.16em] text-yaja-white transition-all hover:bg-transparent hover:text-yaja-red md:inline-block"
      >
        문의하기
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector("[data-header]") as HTMLElement | null;
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 40) {
        header.classList.add("bg-yaja-dark/80", "backdrop-blur-xl", "border-b", "border-white/5");
      } else {
        header.classList.remove("bg-yaja-dark/80", "backdrop-blur-xl", "border-b", "border-white/5");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
