---
/**
 * StoryScroll — YAJA's port of the Banas reference video, rebuilt
 * 1:1 in a scroll-pinned cinematic.
 *
 * Eight scenes cross-fade above a fixed LED-screen background loop
 * (the Higgsfield-generated reflection video). A massive blurred
 * "YAJA" wordmark sits behind every scene — that's the move Banas
 * leans on to give the whole video a single brand signature.
 *
 *   01 Intro tagline       — beyond time, beyond space, …
 *   02 Rapid showcase      — drama thumbs flash centered, one at a time
 *                            (auto-play, ~200ms per thumb)
 *   03 Project showcase 1  — Vaseline campaign card
 *   04 Service highlight   — fake YAJA dashboard card (Banas UI moment)
 *   05 Project showcase 2  — Samsung campaign card
 *   06 Three-step process  — Concept. Create. Distribute. + grid
 *   07 Big numbers stats   — 19억 / 682만 / 183만
 *   08 Positioning slogan  — No script. No actor. No limits.
 *   09 Final logo + CTA    — YAJA™ Start a project
 */
import { hero, stats, projects } from "@/lib/site";

const proj1 = projects[0]; // Vaseline
const proj2 = projects[1]; // Samsung
const gridProjects = projects.slice(0, 4);

// 36 drama thumbnails extracted from YAJA project videos at varied
// timestamps. These pop into the grid one-by-one (Banas-style
// stagger entrance) at the climax of the scroll.
const ALL_THUMBS = Array.from({ length: 36 }, (_, i) =>
  `/screens/grid/thumb-${String(i + 1).padStart(2, "0")}.jpg`,
);

// Rapid-fire showcase — scroll-driven flipbook. Each thumb owns a
// 1/N slice of the scene's scroll window. As you scroll through the
// scene, exactly one thumb is visible at a time and SNAPS to the next
// when the scroll crosses the next threshold. Stop mid-slice and the
// current thumb stays put (no auto-cycle).
const RAPID_THUMBS = ALL_THUMBS.slice(0, 16);

// We use 32 thumbs for a clean 8 col × 4 row final grid. Each gets a
// pseudo-random delay so the appearance order feels organic — but
// deterministic across page loads so the SSR markup stays stable.
const FINAL_THUMBS = ALL_THUMBS.slice(0, 32);
// Halton-2 sequence yields a well-distributed [0,1] for staggered timings.
function halton(i: number, base: number): number {
  let f = 1, r = 0, k = i + 1;
  while (k > 0) { f /= base; r += f * (k % base); k = Math.floor(k / base); }
  return r;
}
const finalThumbsWithDelay = FINAL_THUMBS.map((src, i) => ({
  src,
  delay: halton(i, 2), // 0..1 normalized
}));

// Steps scene: 3 vertical columns of drama stills, each scrolling
// upward at its own speed (roll-up marquee). All 3 columns float in
// together when the scene appears.
// Each column gets 8 thumbs (duplicated for seamless loop).
const STEPS_COL_COUNT = 3;
const STEPS_PER_COL = 8;
const stepsColumns: string[][] = Array.from(
  { length: STEPS_COL_COUNT },
  (_, c) => {
    const offset = c * 7;
    return Array.from({ length: STEPS_PER_COL }, (_, i) =>
      ALL_THUMBS[(offset + i * 3) % ALL_THUMBS.length],
    );
  },
);
---

<!-- ===== Fixed LED background video (behind everything) ===== -->
<div class="story-bg" aria-hidden="true">
  {
    hero.video && (
      <video
        poster={hero.videoPoster || undefined}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        class="story-bg-video"
      >
        <source src="/videos/yaja-led-bg.webm" type="video/webm" />
        <source src={hero.video} type="video/mp4" />
      </video>
    )
  }
  <!-- Gentle dim so foreground text reads -->
  <div class="story-bg-tint"></div>
</div>

<!-- ===== Huge blurred YAJA wordmark — Banas signature move.
     Sits BEHIND scene content but IN FRONT of the LED bg, so the
     LED glows through the letters. Slowly drifts with scroll for
     parallax depth. ===== -->
<div class="story-mark" aria-hidden="true">
  <span class="story-mark-text">YAJA</span>
</div>

<!-- ===== Top-right scene counter ===== -->
<div class="scene-counter" id="scene-counter">
  <span class="red">01</span> / 09 — Intro
</div>

<!-- ===== Story container — 800vh tall, holds the sticky stage ===== -->
<div class="story" id="story">
  <div class="stage">

    <!-- Scene 0: Intro tagline.
         Line 1 floats up on page load (CSS keyframe).
         Line 2 + subtitle rise on scroll.
         Within each line, "Beyond" / "beyond" sits in gray and the
         payload ("time," / "space.") is bold white. -->
    <section class="scene scene-0" id="scene0">
      <p class="s0-tagline">
        <span class="line" data-line="1">
          <span class="dim">Beyond</span> <span class="loud">time,</span>
        </span>
        <span class="line" data-line="2">
          <span class="dim">beyond</span> <span class="loud">space.</span>
        </span>
      </p>
      <p class="s0-sub">We create the best with our creativity.</p>
    </section>

    <!-- Scene 1b: Rapid-fire showcase — scroll-driven flipbook.
         Each thumb gets a 1/N slice of this scene's scroll progress;
         the script flips exactly one visible at a time. -->
    <section class="scene scene-rapid" id="sceneRapid">
      <div class="rapid-stage" aria-hidden="true">
        {
          RAPID_THUMBS.map((src, i) => (
            <div class="rapid-thumb" data-index={i}>
              <img src={src} alt="" loading="lazy" />
            </div>
          ))
        }
      </div>
      <p class="rapid-caption">drama, every angle.</p>
    </section>

    <!-- Scene 1: Project showcase 1 — Vaseline (Banas "OUT OF THE BOX" moment) -->
    <section class="scene scene-ad" id="scene1">
      <div class="ad-card">
        {
          proj1?.video && (
            <video
              src={proj1.video}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          )
        }
        <div class="ad-meta">
          <h2 class="ad-title">CARE EVERY DAY.</h2>
          <p class="ad-body">
            일상 속 케어 스토리를 숏폼 드라마로.<br />
            단일 PR <strong>12,342,129회</strong> 조회.
          </p>
          <div class="ad-footer">
            <span class="ad-badge">Branded Series</span>
            <span class="ad-brand">{proj1?.brand ?? "Vaseline"} × YAJA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Scene 2: Service highlight modal — Banas "AI-generated banners" moment -->
    <section class="scene scene-modal" id="scene2">
      <div class="modal-card">
        <div class="modal-head">
          <span class="modal-label">★ PROMPT</span>
          <span class="modal-action">Generate →</span>
        </div>
        <p class="modal-input">
          Branded short-form drama for every platform, every audience.
        </p>
        <div class="modal-progress">
          <span class="bar"><span class="fill"></span></span>
          <span class="modal-meta">YAJA · K-Short Drama</span>
        </div>
      </div>
    </section>

    <!-- Scene 3: Project showcase 2 — Samsung (Banas "FILL EVERY FRAME" moment) -->
    <section class="scene scene-ad" id="scene3">
      <div class="ad-card vertical">
        {
          proj2?.video && (
            <video
              src={proj2.video}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          )
        }
        <div class="ad-meta">
          <h2 class="ad-title">FILL EVERY EPISODE.</h2>
          <p class="ad-body">
            인기 드라마 시리즈 안에서 자연스러운 제품 노출.<br />
            2 에피소드로 <strong>4,544,123회</strong> 조회.
          </p>
          <div class="ad-footer">
            <span class="ad-badge">Drama PPL</span>
            <span class="ad-brand">{proj2?.brand ?? "SAMSUNG"} × YAJA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Scene 4: 3-step process — Banas "Type. Generate. Ship." layout
         ported 1:1. Left text column with progressive emphasis, right
         grid bleeds off the right edge of the viewport. -->
    <section class="scene scene-steps" id="scene4">
      <div class="steps-left">
        <ol class="steps-list" aria-label="How YAJA works">
          <li class="step step-1">Concept.</li>
          <li class="step step-2">Create.</li>
          <li class="step step-3">Distribute.</li>
        </ol>
        <p class="steps-foot">
          Describe the story you want,<br />
          YAJA delivers the drama.
        </p>
      </div>
      <!-- 3-column vertical roll-up marquee. All columns fade in
           together when scene becomes visible; each column then
           scrolls upward at its own pace via CSS keyframes. The
           thumbs in each column repeat twice so the upward translate
           loops seamlessly. -->
      <div class="steps-marquee" aria-hidden="true">
        {
          stepsColumns.map((col, c) => (
            <div class={`steps-col steps-col-${c}`}>
              {[...col, ...col].map((src) => (
                <img src={src} alt="" loading="lazy" />
              ))}
            </div>
          ))
        }
      </div>
    </section>

    <!-- Scene 5: Big numbers stats — Banas "10s 81x $0" moment -->
    <section class="scene scene-stats" id="scene5">
      <div class="stats-row">
        {
          stats.slice(0, 3).map((s, i) => (
            <div class="stat-cell">
              <div class="stat-val">
                <span class="num" data-target={s.numeric}>0</span>
                <span class="u">{s.unit}</span>
              </div>
              <div class="stat-label">
                {i === 0 && "Total Views"}
                {i === 1 && "Followers"}
                {i === 2 && "Avg / Episode"}
              </div>
            </div>
          ))
        }
      </div>
      <p class="stats-tag">★ TikTok Awards 2024 — Video of The Year</p>
    </section>

    <!-- Scene 6: Positioning slogan — Banas "No designer / needed" moment -->
    <section class="scene scene-slogan" id="scene6">
      <p class="slogan">
        <span class="line" data-line="1">No script.</span>
        <span class="line" data-line="2">No actor.</span>
        <span class="line" data-line="3">No limits.</span>
      </p>
      <p class="slogan-sub">
        YAJA가 자체 IP, 자체 배우, 자체 스튜디오로 모든 단계를 책임집니다.
      </p>
    </section>

    <!-- Scene 7: Final logo + CTA — Banas "Banas™ Start for free" moment -->
    <section class="scene scene-final" id="scene7">
      <!-- 8×4 grid of YAJA drama stills as scene bg. Each thumb POP-INs
           at its own delayed scroll moment — that's the Banas-style
           "バババっと" flurry where the grid assembles one tile at a
           time over a couple seconds of scroll. -->
      <div class="thumb-grid final-grid-thumbs" aria-hidden="true">
        {
          finalThumbsWithDelay.map(({ src, delay }) => (
            <div class="pop-thumb" data-delay={delay.toFixed(3)}>
              <img src={src} alt="" loading="lazy" />
            </div>
          ))
        }
      </div>

      <div class="final-center">
        <!-- DESIGN.md §3.1 — use the official combined YAJA logo
             (flame + wordmark) rather than re-typing the brand. -->
        <img
          src="/logos/yaja-symbol/red-symbol.png"
          alt="YAJA"
          class="final-logo"
          width="829"
          height="443"
        />
        <a href="mailto:info@yajacamp.com" class="final-cta">Start a project</a>
        <p class="final-foot">yajacamp.com</p>
      </div>
    </section>

  </div>
</div>

<!-- ===== Scroll-down indicator (bottom-right) =====
     Hides itself once the user has scrolled past the Intro scene. -->
<div class="scroll-cue" id="scroll-cue" aria-hidden="true">
  <span class="scroll-cue-label">Scroll</span>
  <span class="scroll-cue-arrow">↓</span>
</div>

<!-- ===== Bottom progress bar ===== -->
<div class="progress" id="story-progress"></div>

<style is:global>
  /* ===== Fixed LED background video — always behind everything ===== */
  .story-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .story-bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.75;
  }
  .story-bg-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(30, 30, 30, 0.55) 0%,
      rgba(30, 30, 30, 0.25) 38%,
      rgba(30, 30, 30, 0.7) 100%
    );
  }

  /* ===== Huge blurred YAJA wordmark — Banas-style signature bg ===== */
  .story-mark {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    pointer-events: none;
  }
  /* DESIGN.md §3.1: YAJA wordmark uses Nohemi specifically. */
  .story-mark-text {
    font-family: "Nohemi", "Pretendard", system-ui, sans-serif;
    font-weight: 900;
    font-size: 48vw;
    letter-spacing: -0.08em;
    line-height: 1;
    color: rgba(255, 255, 255, 0.06);
    filter: blur(28px);
    transform: scaleY(0.85);
    white-space: nowrap;
    will-change: transform;
  }

  /* ===== Scene counter (top-right pill) ===== */
  .scene-counter {
    position: fixed;
    top: 80px;
    right: 24px;
    z-index: 50;
    padding: 8px 16px;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-yaja-border);
    backdrop-filter: blur(8px);
  }
  .scene-counter .red {
    color: var(--color-yaja-red);
  }

  /* ===== Story container & sticky stage ===== */
  .story {
    position: relative;
    height: 900vh; /* 9 scenes × 100vh */
    z-index: 2;
  }
  .story .stage {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }
  .story .scene {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 32px;
    opacity: 0;
    will-change: opacity, transform;
  }

  /* ----- Scene 0: Intro tagline -----
     "Beyond time, beyond space." across two lines. Within each line,
     ".dim" sits in gray + lighter weight, ".loud" is bold white. */
  .s0-tagline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-family: var(--font-num);
    font-size: clamp(36px, 5.6vw, 92px);
    letter-spacing: -0.025em;
    line-height: 1.05;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.5);
  }
  .s0-tagline .dim {
    color: var(--color-yaja-border);
    font-weight: 500;
  }
  .s0-tagline .loud {
    color: var(--color-yaja-white);
    font-weight: 900;
  }
  /* (Red caret-block after "space." removed per request.) */

  /* Line 1 floats up on page load — slow + dramatic. Line 2 + sub
     stay hidden until the user starts scrolling; JS interpolates
     them from scroll progress (see applyIntroLinesScroll). */
  .s0-tagline .line {
    opacity: 0;
    transform: translate3d(0, 64px, 0);
    will-change: opacity, transform;
  }
  .s0-tagline .line:nth-child(1) {
    animation: s0-line1-in 2.4s cubic-bezier(0.16, 1, 0.3, 1) 1.6s forwards;
  }
  @keyframes s0-line1-in {
    from {
      opacity: 0;
      transform: translate3d(0, 64px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  /* Smaller subtitle below the tagline, also scroll-tied. */
  .s0-sub {
    margin-top: clamp(24px, 3vh, 40px);
    font-family: var(--font-num);
    font-size: clamp(14px, 1.4vw, 20px);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-yaja-border);
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .s0-tagline .line,
    .s0-sub {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
  }

  /* ----- scene-rapid: scroll-driven flipbook of drama stills -----
     Each .rapid-thumb is absolutely centered and starts hidden. The
     script sets exactly ONE to display:block based on the current
     scroll-progress slice within this scene. No CSS transitions or
     animation — the swap must be instant, so the eye reads it as a
     hard cut (matches the Banas 3-5s film-cut feel). */
  .scene-rapid {
    padding: 32px;
  }
  .rapid-stage {
    position: relative;
    /* Match the Project section card width + 9:16 ratio so the
       rapid showcase and the project cards feel continuous. */
    width: min(540px, 80vw);
    aspect-ratio: 9 / 16;
    max-height: 80vh;
  }
  .rapid-thumb {
    position: absolute;
    inset: 0;
    /* DESIGN.md §5.2 — 4–8px range, use the largest token */
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-yaja-charcoal);
    display: none;
    box-shadow:
      0 50px 100px -25px rgba(0, 0, 0, 0.85),
      0 20px 50px -15px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .rapid-thumb.is-active {
    display: block;
  }
  .rapid-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .rapid-caption {
    position: absolute;
    bottom: 8vh;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-num);
    font-weight: 800;
    font-size: clamp(16px, 1.6vw, 22px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-yaja-border);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.7);
  }

  /* Respect reduced motion — keep first thumb visible only */
  @media (prefers-reduced-motion: reduce) {
    .rapid-thumb {
      display: none;
    }
    .rapid-thumb:first-child {
      display: block;
    }
  }

  /* ----- scene-ad: Banas "single floating ad" moment ----- */
  .scene-ad {
    padding: 32px 5vw;
  }
  .ad-card {
    position: relative;
    width: min(540px, 80vw);
    aspect-ratio: 9 / 16;
    background: var(--color-yaja-dark);
    /* DESIGN.md §5.2 — 4–8px */
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      0 60px 120px -20px rgba(0, 0, 0, 0.85),
      0 30px 60px -15px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .ad-card video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
  }
  .ad-meta {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 36px 32px 32px;
    background: linear-gradient(
      180deg,
      transparent 40%,
      rgba(0, 0, 0, 0.85) 100%
    );
    text-align: left;
  }
  .ad-title {
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(32px, 4.5vw, 60px);
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: var(--color-yaja-white);
    margin-bottom: 16px;
  }
  .ad-body {
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-yaja-border);
    margin-bottom: 24px;
  }
  .ad-body strong {
    color: var(--color-yaja-white);
    font-weight: 700;
  }
  .ad-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .ad-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--color-yaja-red);
    color: var(--color-yaja-white);
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 4px;
  }
  .ad-brand {
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-yaja-gray);
  }

  /* ----- scene-modal: Banas UI card moment ----- */
  .modal-card {
    width: min(640px, 88vw);
    padding: 22px 24px 20px;
    background: rgba(245, 245, 247, 0.96);
    color: var(--color-yaja-dark);
    /* DESIGN.md §5.2 — 4–8px */
    border-radius: var(--radius-lg);
    box-shadow:
      0 60px 120px -20px rgba(0, 0, 0, 0.85),
      0 24px 60px -15px rgba(0, 0, 0, 0.5);
    text-align: left;
  }
  .modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .modal-label {
    color: var(--color-yaja-red);
  }
  .modal-action {
    color: var(--color-yaja-gray-mid);
  }
  .modal-input {
    font-size: clamp(14px, 1.3vw, 17px);
    color: var(--color-yaja-dark);
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 16px;
  }
  .modal-progress {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }
  .modal-progress .bar {
    flex: 1;
    height: 3px;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    overflow: hidden;
  }
  .modal-progress .fill {
    display: block;
    width: 64%;
    height: 100%;
    background: linear-gradient(
      90deg,
      var(--color-yaja-dark) 0%,
      var(--color-yaja-gray-mid) 100%
    );
  }
  .modal-meta {
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-yaja-gray-mid);
  }

  /* ----- scene-steps: Banas "Type. Generate. Ship." layout =====
     Override the default .scene flex column so we can position the
     left text and the bleed-right grid independently. */
  .scene-steps {
    flex-direction: row !important;
    align-items: stretch !important;
    justify-content: flex-start !important;
    text-align: left !important;
    padding: 0 !important;
  }
  /* Left text column — fixed width, vertically centered, sits over
     the LED bg. */
  .steps-left {
    flex: 0 0 auto;
    width: clamp(280px, 32vw, 460px);
    padding: 0 clamp(40px, 5vw, 96px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    z-index: 3;
  }
  .steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  /* Progressive emphasis: first word dim/light, second white, third
     pure white biggest — matches Banas "Type. Generate. Ship." */
  .step {
    font-family: var(--font-num);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.045em;
  }
  .step-1 {
    font-size: clamp(40px, 5.6vw, 92px);
    color: rgba(255, 255, 255, 0.55);
  }
  .step-2 {
    font-size: clamp(48px, 6.6vw, 108px);
    color: rgba(255, 255, 255, 0.85);
  }
  .step-3 {
    font-size: clamp(56px, 7.4vw, 124px);
    color: var(--color-yaja-white);
  }
  .steps-foot {
    margin-top: 36px;
    max-width: 24ch;
    font-size: 13px;
    color: var(--color-yaja-border);
    line-height: 1.55;
    letter-spacing: 0.01em;
  }
  /* 3-column vertical roll-up marquee — right half of the stage. */
  .steps-marquee {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    right: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding: 4vh 3vw 4vh 0;
    overflow: hidden;
    z-index: 2;
    /* Whole marquee fades up when scene enters (matches the
       scene's own float-up so user reads "all three at once"). */
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    transition: opacity 0.9s ease, transform 0.9s ease;
  }
  .scene-steps.is-visible .steps-marquee {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
  /* Each column scrolls upward continuously at its own speed. */
  .steps-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    will-change: transform;
    animation-name: steps-col-up;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-play-state: paused;
  }
  .scene-steps.is-visible .steps-col {
    animation-play-state: running;
  }
  .steps-col img {
    width: 100%;
    aspect-ratio: 9 / 14;
    object-fit: cover;
    border-radius: var(--radius-md);
    background: var(--color-yaja-charcoal);
    display: block;
  }
  /* Each column scrolls -50% (the duplicate point) over its own period */
  @keyframes steps-col-up {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(0, -50%, 0); }
  }
  .steps-col-0 { animation-duration: 28s; }
  .steps-col-1 { animation-duration: 42s; animation-delay: -8s; }
  .steps-col-2 { animation-duration: 34s; animation-delay: -16s; }
  /* Soft edges so the marquee dissolves into the LED bg */
  .steps-marquee::before,
  .steps-marquee::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 14%;
    pointer-events: none;
    z-index: 3;
  }
  .steps-marquee::before {
    top: 0;
    background: linear-gradient(180deg, var(--color-yaja-dark), transparent);
  }
  .steps-marquee::after {
    bottom: 0;
    background: linear-gradient(0deg, var(--color-yaja-dark), transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .steps-col {
      animation: none !important;
      transform: translate3d(0, -25%, 0);
    }
  }
  @media (max-width: 900px) {
    .scene-steps {
      flex-direction: column !important;
      justify-content: center !important;
    }
    .steps-left {
      width: 100%;
      padding: 24px;
      align-items: center;
    }
    .steps-list {
      align-items: center;
    }
    .steps-marquee {
      position: relative;
      left: 0;
      right: 0;
      top: auto;
      bottom: auto;
      height: 38vh;
      margin-top: 24px;
      padding: 0 16px;
    }
  }

  /* ----- scene-stats: big numbers ----- */
  .stats-row {
    display: flex;
    gap: clamp(36px, 8vw, 120px);
    flex-wrap: wrap;
    justify-content: center;
  }
  .stat-cell {
    text-align: center;
  }
  /* User preferred Pretendard for the stat digits (Nohemi read as
     uneven at display size). Bumped overall scale + tightened
     tracking so the digits still feel cinematic. */
  .stat-val {
    font-family: var(--font-num); /* Pretendard with tabular nums */
    font-variant-numeric: tabular-nums;
    font-weight: 900;
    font-size: clamp(92px, 14vw, 220px);
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: var(--color-yaja-white);
  }
  .stat-val .u {
    font-family: var(--font-kr);
    font-size: 0.3em;
    color: var(--color-yaja-gray);
    margin-left: 10px;
    font-weight: 700;
    letter-spacing: 0;
  }
  .stat-label {
    margin-top: 16px;
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-yaja-border);
  }
  .stats-tag {
    margin-top: 64px;
    font-family: var(--font-num);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-yaja-red);
  }

  /* ----- scene-slogan: Banas "No designer needed" moment ----- */
  .slogan {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(48px, 9vw, 156px);
    letter-spacing: -0.045em;
    line-height: 0.96;
    color: var(--color-yaja-white);
    text-align: left;
  }
  .slogan .line {
    opacity: 0;
    transform: translate3d(0, 32px, 0);
    will-change: opacity, transform;
  }
  .slogan .line:last-child {
    color: var(--color-yaja-red);
  }
  .slogan-sub {
    margin-top: 32px;
    max-width: 42ch;
    font-size: 14px;
    color: var(--color-yaja-border);
    line-height: 1.6;
    text-align: left;
  }

  /* ----- scene-final: huge wordmark + CTA + grid bg ----- */
  .scene-final {
    padding: 0;
  }

  /* ===== Stagger pop-in thumb grid (Banas "バババっと" flurry) =====
     Each .pop-thumb gets a data-delay (0..1). The script reads scroll
     progress and per-thumb interpolates opacity + scale + blur from
     "not yet" → "fully landed". When many thumbs share a scroll window
     with random delays, the eye sees them pop in one after another. */
  .thumb-grid {
    display: grid;
    gap: 8px;
  }
  .pop-thumb {
    aspect-ratio: 9 / 14;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-yaja-charcoal);
    opacity: 0;
    transform: scale(1.35);
    filter: blur(8px);
    will-change: opacity, transform, filter;
  }
  .pop-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* NOTE: .steps-grid-thumbs is defined above next to .scene-steps
     (3 columns, right-hugged). Don't redefine it here — a later
     rule was overriding it back to 4 columns and breaking the
     Banas "Type. Generate. Ship." layout. */

  /* final scene — 8×4 grid filling the full stage as bg */
  .final-grid-thumbs {
    position: absolute;
    inset: 16px;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(4, 1fr);
    opacity: 0.55;
    z-index: 1;
  }
  .final-grid-thumbs .pop-thumb {
    border-radius: var(--radius-sm);
  }

  /* Respect reduced motion — show static at full state */
  @media (prefers-reduced-motion: reduce) {
    .pop-thumb {
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }
  }
  .final-center {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: radial-gradient(
      ellipse at center,
      rgba(30, 30, 30, 0.85) 0%,
      rgba(30, 30, 30, 0.55) 50%,
      transparent 100%
    );
    padding: 64px 96px;
    /* DESIGN.md §5.2 — radii capped at 8px; this is a vignette
       backdrop so the radius barely shows anyway, but stay strict. */
    border-radius: var(--radius-lg);
  }
  /* DESIGN.md §3.1 — official combined logo (flame + wordmark). */
  .final-logo {
    width: clamp(280px, 38vw, 560px);
    height: auto;
    display: block;
    filter: drop-shadow(0 12px 32px rgba(255, 72, 72, 0.25));
  }
  .final-cta {
    margin-top: 32px;
    padding: 16px 36px;
    background: var(--color-yaja-white);
    color: var(--color-yaja-dark);
    font-family: var(--font-num);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .final-cta:hover {
    transform: translateY(-2px);
  }
  .final-foot {
    margin-top: 22px;
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-yaja-gray-mid);
  }

  /* ----- Scroll-down indicator ----- */
  .scroll-cue {
    position: fixed;
    right: 24px;
    bottom: 28px;
    z-index: 55;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    pointer-events: none;
    opacity: 0;
    transform: translate3d(0, 8px, 0);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  /* Fades in after the intro tagline lands (≈ 3.4s) */
  .scroll-cue.is-ready {
    opacity: 0.85;
    transform: translate3d(0, 0, 0);
  }
  /* Hides once user has scrolled past the intro */
  .scroll-cue.is-hidden {
    opacity: 0 !important;
    transform: translate3d(0, 8px, 0) !important;
  }
  .scroll-cue-label {
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    writing-mode: vertical-rl;
  }
  .scroll-cue-arrow {
    font-size: 18px;
    color: var(--color-yaja-white);
    line-height: 1;
    animation: scroll-cue-bounce 1.8s ease-in-out infinite;
  }
  @keyframes scroll-cue-bounce {
    0%, 100% { transform: translate3d(0, 0, 0); opacity: 0.6; }
    50%      { transform: translate3d(0, 6px, 0); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue-arrow {
      animation: none;
    }
  }

  /* ----- Progress bar ----- */
  .story #story-progress,
  .progress {
    position: fixed;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--color-yaja-red);
    z-index: 60;
    transition: width 0.08s linear;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ===== Scene cross-fade — single ScrollTrigger drives all 8 scenes
  // The Banas reference packs 8 distinct moments into ~22s of video; we
  // give each a roughly equal slice of 800vh of scroll progress.

  interface SceneSpec {
    sel: string;
    label: string;
    fadeIn: number;
    holdStart: number;
    holdEnd: number;
    fadeOut: number;
    el?: HTMLElement | null;
  }

  // Nine scenes packed into [0, 1]. Rapid Showcase gets a generous
  // ~13% slice so the CSS keyframe (4s cycle) has time to play through
  // even with users who scroll moderately fast.
  const sceneSpecs: SceneSpec[] = [
    {
      sel: "#scene0",
      label: "01 / 09 — Intro",
      fadeIn: -Infinity,
      holdStart: 0,
      holdEnd: 0.06,
      fadeOut: 0.1,
    },
    {
      sel: "#sceneRapid",
      label: "02 / 09 — Showcase",
      fadeIn: 0.11,
      holdStart: 0.14,
      holdEnd: 0.21,
      fadeOut: 0.24,
    },
    {
      sel: "#scene1",
      label: "03 / 09 — Project: Vaseline",
      fadeIn: 0.25,
      holdStart: 0.28,
      holdEnd: 0.33,
      fadeOut: 0.37,
    },
    {
      sel: "#scene2",
      label: "04 / 09 — Service",
      fadeIn: 0.38,
      holdStart: 0.4,
      holdEnd: 0.44,
      fadeOut: 0.48,
    },
    {
      sel: "#scene3",
      label: "05 / 09 — Project: Samsung",
      fadeIn: 0.49,
      holdStart: 0.52,
      holdEnd: 0.57,
      fadeOut: 0.61,
    },
    {
      sel: "#scene4",
      label: "06 / 09 — Process",
      fadeIn: 0.62,
      holdStart: 0.65,
      holdEnd: 0.71,
      fadeOut: 0.74,
    },
    {
      sel: "#scene5",
      label: "07 / 09 — Numbers",
      fadeIn: 0.75,
      holdStart: 0.77,
      holdEnd: 0.82,
      fadeOut: 0.85,
    },
    {
      sel: "#scene6",
      label: "08 / 09 — Slogan",
      fadeIn: 0.86,
      holdStart: 0.88,
      holdEnd: 0.92,
      fadeOut: 0.94,
    },
    {
      sel: "#scene7",
      label: "09 / 09 — YAJA",
      fadeIn: 0.95,
      holdStart: 0.97,
      holdEnd: Infinity,
      fadeOut: Infinity,
    },
  ];

  sceneSpecs.forEach((s) => {
    s.el = document.querySelector<HTMLElement>(s.sel);
  });

  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
  const clamp01 = (x: number) => Math.max(0, Math.min(1, x));
  const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
  const easeInCubic = (t: number) => t * t * t;

  const ENTER_Y = 80; // px
  const EXIT_Y = -60;

  function computeSceneState(p: number, s: SceneSpec) {
    if (p < s.fadeIn) return { opacity: 0, y: ENTER_Y, scale: 1.02 };
    if (p < s.holdStart) {
      const raw = clamp01((p - s.fadeIn) / (s.holdStart - s.fadeIn));
      const t = easeOutCubic(raw);
      return { opacity: t, y: lerp(ENTER_Y, 0, t), scale: lerp(1.02, 1, t) };
    }
    if (p <= s.holdEnd) return { opacity: 1, y: 0, scale: 1 };
    if (p <= s.fadeOut) {
      const raw = clamp01((p - s.holdEnd) / (s.fadeOut - s.holdEnd));
      const t = easeInCubic(raw);
      return { opacity: 1 - t, y: lerp(0, EXIT_Y, t), scale: lerp(1, 0.98, t) };
    }
    return { opacity: 0, y: EXIT_Y, scale: 0.98 };
  }

  sceneSpecs.forEach((s, i) => {
    if (!s.el) return;
    if (i === 0) {
      gsap.set(s.el, { opacity: 1, y: 0, scale: 1 });
    } else {
      gsap.set(s.el, { opacity: 0, y: ENTER_Y, scale: 1.02 });
    }
  });

  // Background wordmark drifts upward subtly with scroll for parallax.
  const mark = document.querySelector<HTMLElement>(".story-mark-text");
  // Process scene gets a .is-visible toggle so its column-marquees
  // fade up + start scrolling only while the scene is on screen.
  const stepsScene = document.querySelector<HTMLElement>(".scene-steps");

  // Scroll-down cue. Reveal after the intro tagline lands (~3.5s),
  // hide as soon as the user scrolls into the next scene.
  const scrollCue = document.getElementById("scroll-cue");
  if (scrollCue) {
    window.setTimeout(() => scrollCue.classList.add("is-ready"), 3500);
  }

  ScrollTrigger.create({
    trigger: ".story",
    start: "top top",
    end: "bottom bottom",
    scrub: true,
    onUpdate: (self) => {
      const p = self.progress;
      sceneSpecs.forEach((s) => {
        if (!s.el) return;
        const { opacity, y, scale } = computeSceneState(p, s);
        s.el.style.opacity = String(opacity);
        s.el.style.transform = `translate3d(0, ${y}px, 0) scale(${scale})`;
      });
      // Line 1 is time-based (CSS keyframe on load). Lines 2 + 3 are
      // scroll-tied so they "rise as you scroll" the way the user
      // wanted.
      applyIntroLinesScroll(p);
      applySloganLines(p);
      applyPopThumbs(p);
      applyRapidThumbs(p);
      if (mark) {
        // Drift -40px → +40px across full scroll, slight scale.
        const dy = (p - 0.5) * 80;
        const sc = 0.85 + p * 0.15;
        mark.style.transform = `scaleY(0.85) translate3d(0, ${dy}px, 0) scale(${sc})`;
      }
      // Hide the scroll cue once the user has moved past the Intro
      // scene (Intro fades out at p=0.10).
      if (scrollCue) {
        if (p > 0.04) scrollCue.classList.add("is-hidden");
        else scrollCue.classList.remove("is-hidden");
      }
      // Toggle .is-visible on the Process scene so its column
      // marquees fade up + start scrolling when the scene enters.
      if (stepsScene) {
        if (p >= 0.55 && p <= 0.76) stepsScene.classList.add("is-visible");
        else stepsScene.classList.remove("is-visible");
      }
    },
  });

  // ===== Intro line 2 + subtitle are scroll-tied =====
  // Line 1 ("Beyond time,") rises via CSS keyframe on page load.
  // Line 2 ("beyond space.") + subtitle stay hidden until the user
  // starts scrolling, then each rises from below over its own slice.
  const introScrollTargets = (() => {
    const all = Array.from(
      document.querySelectorAll<HTMLElement>(".s0-tagline .line"),
    );
    const line2 = all[1];
    const sub = document.querySelector<HTMLElement>(".s0-sub");
    return [line2, sub].filter((el): el is HTMLElement => Boolean(el));
  })();
  const INTRO_STARTS_2_S = [0.012, 0.038]; // line 2, then subtitle
  const INTRO_DUR_2_S = 0.028;
  function applyIntroLinesScroll(p: number) {
    introScrollTargets.forEach((el, i) => {
      const start = INTRO_STARTS_2_S[i] ?? 0;
      const raw = clamp01((p - start) / INTRO_DUR_2_S);
      const t = easeOutCubic(raw);
      el.style.opacity = String(t);
      el.style.transform = `translate3d(0, ${(1 - t) * 28}px, 0)`;
    });
  }
  applyIntroLinesScroll(0);

  //===== Rapid-fire showcase — scroll-driven flipbook =====
  // Map the Rapid Showcase scene's scroll window onto N equal slices
  // (one per thumb). Set exactly one thumb to .is-active per frame
  // based on which slice we're in. Outside the scene window, no thumb
  // is active (the scene's own opacity handles fade-in/out).
  const rapidThumbs = Array.from(
    document.querySelectorAll<HTMLElement>(".rapid-thumb"),
  );
  // Match the sceneSpecs entry for #sceneRapid above. We use the *hold*
  // window so the flipbook plays only while the scene is at full
  // opacity (the lead-in / lead-out are handled by the normal scene
  // float-up motion).
  const RAPID_START = 0.11;
  const RAPID_END = 0.24;
  let rapidActive = -1;

  // Showcase is now time-driven, not scroll-driven. Once the user
  // enters the scene, an interval cycles every thumb (show 250ms,
  // gap 80ms) until all 16 have played, regardless of scroll speed.
  // The scene's own scroll window remains in control of fade-in /
  // fade-out, but selection is time-based.
  const RAPID_SHOW_MS = 250;
  const RAPID_GAP_MS = 80;
  let rapidTimer: number | null = null;
  let rapidCycleIdx = 0;

  function setRapidVisible(idx: number) {
    if (idx === rapidActive) return;
    if (rapidActive !== -1) rapidThumbs[rapidActive]?.classList.remove("is-active");
    if (idx !== -1) rapidThumbs[idx]?.classList.add("is-active");
    rapidActive = idx;
  }

  function clearRapidCycle() {
    if (rapidTimer !== null) {
      clearTimeout(rapidTimer);
      rapidTimer = null;
    }
    setRapidVisible(-1);
    rapidCycleIdx = 0;
  }

  function tickRapidCycle() {
    // Show current thumb for SHOW_MS, then GAP (no thumb) for GAP_MS,
    // then advance. After last thumb + gap, stop (leave nothing
    // visible so the LED bg shows through the rest of the hold).
    if (rapidCycleIdx >= rapidThumbs.length) {
      setRapidVisible(-1);
      rapidTimer = null;
      return;
    }
    setRapidVisible(rapidCycleIdx);
    rapidTimer = window.setTimeout(() => {
      setRapidVisible(-1);
      rapidTimer = window.setTimeout(() => {
        rapidCycleIdx += 1;
        tickRapidCycle();
      }, RAPID_GAP_MS);
    }, RAPID_SHOW_MS);
  }

  function startRapidCycle() {
    if (rapidTimer !== null) return; // already playing
    rapidCycleIdx = 0;
    tickRapidCycle();
  }

  function applyRapidThumbs(p: number) {
    if (rapidThumbs.length === 0) return;
    if (p < RAPID_START || p > RAPID_END) {
      // Outside the scene — reset (so re-entering plays from start)
      if (rapidTimer !== null || rapidActive !== -1) {
        clearRapidCycle();
      }
      return;
    }
    // Inside the scene — kick off the auto-play once
    startRapidCycle();
  }
  // Paint initial state: show first thumb if we're already past 0
  applyRapidThumbs(0);

  // ===== Pop-thumb stagger entrance (Banas "バババっと" effect) =====
  // Two groups of thumbs land in two different scroll windows:
  //   • steps group   — appears while scene-steps is on screen
  //                     (scene fadeIn 0.55 → holdEnd 0.65). We map
  //                     thumb delays (0..1) across 0.55 → 0.66.
  //   • final group   — assembles as user enters the final scene.
  //                     Window: 0.82 → 0.97 so they're mostly placed
  //                     by the time the YAJA™ lockup is centered.
  // Each thumb's window is 0.04 wide (~3% of total scroll) so popping
  // feels punchy not slow.
  interface PopGroup {
    nodes: NodeListOf<HTMLElement>;
    start: number;
    end: number;
  }
  const POP_DURATION = 0.04;
  const popGroups: PopGroup[] = [
    {
      // scene-steps holds 0.65 → 0.71; assemble during the lead-in
      nodes: document.querySelectorAll<HTMLElement>(
        ".steps-grid-thumbs .pop-thumb",
      ),
      start: 0.62,
      end: 0.72,
    },
    {
      // final scene takes over at 0.95; thumbs land 0.86 → 0.98
      nodes: document.querySelectorAll<HTMLElement>(
        ".final-grid-thumbs .pop-thumb",
      ),
      start: 0.86,
      end: 0.98,
    },
  ];

  function applyPopThumbs(p: number) {
    popGroups.forEach((g) => {
      g.nodes.forEach((el) => {
        const delay = parseFloat(el.dataset.delay ?? "0");
        const triggerStart = g.start + delay * (g.end - g.start);
        const raw = clamp01((p - triggerStart) / POP_DURATION);
        const t = easeOutCubic(raw);
        el.style.opacity = String(t);
        el.style.transform = `scale(${lerp(1.35, 1, t)})`;
        el.style.filter = `blur(${lerp(8, 0, t)}px)`;
      });
    });
  }
  applyPopThumbs(0);

  // ===== Slogan line stagger (Scene 7, fadeIn at 0.84) =====
  const sloganLines = Array.from(
    document.querySelectorAll<HTMLElement>(".slogan .line")
  );
  // Slogan scene fadeIn 0.86 → holdStart 0.88
  const SLOGAN_STARTS = [0.865, 0.88, 0.895];
  const SLOGAN_DUR = 0.02;
  function applySloganLines(p: number) {
    sloganLines.forEach((el, i) => {
      const start = SLOGAN_STARTS[i] ?? 0;
      const raw = clamp01((p - start) / SLOGAN_DUR);
      const t = easeOutCubic(raw);
      el.style.opacity = String(t);
      el.style.transform = `translate3d(0, ${(1 - t) * 32}px, 0)`;
    });
  }
  applySloganLines(0);

  // ===== Number count-up — fires when Stats scene fades in =====
  const nums = document.querySelectorAll<HTMLElement>(".scene-stats .num");
  // Numbers scene fadeIn at 0.75 in the new 9-scene layout
  const NUM_FIRE = 0.77;
  const NUM_RESET = 0.72;
  let numsTriggered = false;
  ScrollTrigger.create({
    trigger: ".story",
    start: "top top",
    end: "bottom bottom",
    onUpdate: (self) => {
      if (self.progress >= NUM_FIRE && !numsTriggered) {
        numsTriggered = true;
        nums.forEach((el) => {
          const target = parseInt(el.dataset.target ?? "0", 10);
          const obj = { v: 0 };
          gsap.to(obj, {
            v: target,
            duration: 1.4,
            ease: "power2.out",
            onUpdate: () => (el.textContent = String(Math.round(obj.v))),
          });
        });
      }
      if (self.progress < NUM_RESET) {
        numsTriggered = false;
        nums.forEach((el) => (el.textContent = "0"));
      }
    },
  });

  // ===== Progress bar + scene counter =====
  const counter = document.getElementById("scene-counter");
  const progress = document.getElementById("story-progress");
  ScrollTrigger.create({
    trigger: ".story",
    start: "top top",
    end: "bottom bottom",
    onUpdate: (self) => {
      if (progress) progress.style.width = `${(self.progress * 100).toFixed(1)}%`;
      let active = sceneSpecs[0];
      for (const s of sceneSpecs) {
        if (self.progress >= s.holdStart) active = s;
      }
      if (counter) {
        const [num, ...rest] = active.label.split(" ");
        counter.innerHTML = `<span class="red">${num}</span> ${rest.join(" ")}`;
      }
    },
  });
</script>
