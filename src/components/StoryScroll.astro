---
/**
 * StoryScroll — YAJA's port of the Banas reference video, rebuilt
 * 1:1 in a scroll-pinned cinematic.
 *
 * Eight scenes cross-fade above a fixed LED-screen background loop
 * (the Higgsfield-generated reflection video). A massive blurred
 * "YAJA" wordmark sits behind every scene — that's the move Banas
 * leans on to give the whole video a single brand signature.
 *
 *   01 Intro tagline       — beyond time, beyond space, …
 *   02 Project showcase 1  — Vaseline campaign card
 *   03 Service highlight   — fake YAJA dashboard card (Banas UI moment)
 *   04 Project showcase 2  — Samsung campaign card
 *   05 Three-step process  — Concept. Create. Distribute. + grid
 *   06 Big numbers stats   — 19억 / 682만 / 183만
 *   07 Positioning slogan  — No script. No actor. No limits.
 *   08 Final logo + CTA    — YAJA™ Start a project
 */
import { hero, stats, projects } from "@/lib/site";

const proj1 = projects[0]; // Vaseline
const proj2 = projects[1]; // Samsung
const gridProjects = projects.slice(0, 4);

// 36 drama thumbnails extracted from YAJA project videos at varied
// timestamps. These pop into the grid one-by-one (Banas-style
// stagger entrance) at the climax of the scroll.
const ALL_THUMBS = Array.from({ length: 36 }, (_, i) =>
  `/screens/grid/thumb-${String(i + 1).padStart(2, "0")}.jpg`,
);

// We use 32 thumbs for a clean 8 col × 4 row final grid. Each gets a
// pseudo-random delay so the appearance order feels organic — but
// deterministic across page loads so the SSR markup stays stable.
const FINAL_THUMBS = ALL_THUMBS.slice(0, 32);
// Halton-2 sequence yields a well-distributed [0,1] for staggered timings.
function halton(i: number, base: number): number {
  let f = 1, r = 0, k = i + 1;
  while (k > 0) { f /= base; r += f * (k % base); k = Math.floor(k / base); }
  return r;
}
const finalThumbsWithDelay = FINAL_THUMBS.map((src, i) => ({
  src,
  delay: halton(i, 2), // 0..1 normalized
}));

// Steps scene uses a smaller subset (8 in a 4×2 layout) with the
// same stagger idea but a tighter window.
const STEPS_THUMBS = ALL_THUMBS.slice(8, 16);
const stepsThumbsWithDelay = STEPS_THUMBS.map((src, i) => ({
  src,
  delay: halton(i, 2),
}));
---

<!-- ===== Fixed LED background video (behind everything) ===== -->
<div class="story-bg" aria-hidden="true">
  {
    hero.video && (
      <video
        poster={hero.videoPoster || undefined}
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        class="story-bg-video"
      >
        <source src="/videos/yaja-led-bg.webm" type="video/webm" />
        <source src={hero.video} type="video/mp4" />
      </video>
    )
  }
  <!-- Gentle dim so foreground text reads -->
  <div class="story-bg-tint"></div>
</div>

<!-- ===== Huge blurred YAJA wordmark — Banas signature move.
     Sits BEHIND scene content but IN FRONT of the LED bg, so the
     LED glows through the letters. Slowly drifts with scroll for
     parallax depth. ===== -->
<div class="story-mark" aria-hidden="true">
  <span class="story-mark-text">YAJA</span>
</div>

<!-- ===== Top-right scene counter ===== -->
<div class="scene-counter" id="scene-counter">
  <span class="red">01</span> / 08 — Intro
</div>

<!-- ===== Story container — 800vh tall, holds the sticky stage ===== -->
<div class="story" id="story">
  <div class="stage">

    <!-- Scene 0: Intro tagline — 3 lines stagger up from below -->
    <section class="scene scene-0" id="scene0">
      <p class="s0-tagline">
        <span class="line" data-line="1">beyond time,</span>
        <span class="line" data-line="2">beyond space,</span>
        <span class="line" data-line="3">with the best creativity.</span>
      </p>
    </section>

    <!-- Scene 1: Project showcase 1 — Vaseline (Banas "OUT OF THE BOX" moment) -->
    <section class="scene scene-ad" id="scene1">
      <div class="ad-card">
        {
          proj1?.video && (
            <video
              src={proj1.video}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          )
        }
        <div class="ad-meta">
          <h2 class="ad-title">CARE EVERY DAY.</h2>
          <p class="ad-body">
            일상 속 케어 스토리를 숏폼 드라마로.<br />
            단일 PR <strong>12,342,129회</strong> 조회.
          </p>
          <div class="ad-footer">
            <span class="ad-badge">Branded Series</span>
            <span class="ad-brand">{proj1?.brand ?? "Vaseline"} × YAJA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Scene 2: Service highlight modal — Banas "AI-generated banners" moment -->
    <section class="scene scene-modal" id="scene2">
      <div class="modal-card">
        <div class="modal-head">
          <span class="modal-label">★ PROMPT</span>
          <span class="modal-action">Generate →</span>
        </div>
        <p class="modal-input">
          Branded short-form drama for every platform, every audience.
        </p>
        <div class="modal-progress">
          <span class="bar"><span class="fill"></span></span>
          <span class="modal-meta">YAJA · K-Short Drama</span>
        </div>
      </div>
    </section>

    <!-- Scene 3: Project showcase 2 — Samsung (Banas "FILL EVERY FRAME" moment) -->
    <section class="scene scene-ad" id="scene3">
      <div class="ad-card vertical">
        {
          proj2?.video && (
            <video
              src={proj2.video}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          )
        }
        <div class="ad-meta">
          <h2 class="ad-title">FILL EVERY EPISODE.</h2>
          <p class="ad-body">
            인기 드라마 시리즈 안에서 자연스러운 제품 노출.<br />
            2 에피소드로 <strong>4,544,123회</strong> 조회.
          </p>
          <div class="ad-footer">
            <span class="ad-badge">Drama PPL</span>
            <span class="ad-brand">{proj2?.brand ?? "SAMSUNG"} × YAJA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Scene 4: 3-step process — Banas "Type. Generate. Ship." moment -->
    <section class="scene scene-steps" id="scene4">
      <div class="steps-grid">
        <div class="steps-left">
          <p class="steps-eyebrow">— How we work</p>
          <ol class="steps-list">
            <li class="step">
              <span class="step-num">01.</span>
              <span class="step-name">Concept.</span>
            </li>
            <li class="step">
              <span class="step-num">02.</span>
              <span class="step-name">Create.</span>
            </li>
            <li class="step">
              <span class="step-num">03.</span>
              <span class="step-name">Distribute.</span>
            </li>
          </ol>
          <p class="steps-foot">
            기획에서 송출까지, YAJA 한 곳에서.
          </p>
        </div>
        <div class="steps-right">
          <!-- 4×2 grid of YAJA drama stills. Each thumb POP-INs at its
               own scroll-progress moment for the Banas "バババっと" feel.
               data-delay (0..1) is interpolated against the steps-scene
               window in script. -->
          <div class="thumb-grid steps-grid-thumbs" aria-hidden="true">
            {
              stepsThumbsWithDelay.map(({ src, delay }) => (
                <div class="pop-thumb" data-delay={delay.toFixed(3)}>
                  <img src={src} alt="" loading="lazy" />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Scene 5: Big numbers stats — Banas "10s 81x $0" moment -->
    <section class="scene scene-stats" id="scene5">
      <div class="stats-row">
        {
          stats.slice(0, 3).map((s, i) => (
            <div class="stat-cell">
              <div class="stat-val">
                <span class="num" data-target={s.numeric}>0</span>
                <span class="u">{s.unit}</span>
              </div>
              <div class="stat-label">
                {i === 0 && "Total Views"}
                {i === 1 && "Followers"}
                {i === 2 && "Avg / Episode"}
              </div>
            </div>
          ))
        }
      </div>
      <p class="stats-tag">★ TikTok Awards 2024 — Video of The Year</p>
    </section>

    <!-- Scene 6: Positioning slogan — Banas "No designer / needed" moment -->
    <section class="scene scene-slogan" id="scene6">
      <p class="slogan">
        <span class="line" data-line="1">No script.</span>
        <span class="line" data-line="2">No actor.</span>
        <span class="line" data-line="3">No limits.</span>
      </p>
      <p class="slogan-sub">
        YAJA가 자체 IP, 자체 배우, 자체 스튜디오로 모든 단계를 책임집니다.
      </p>
    </section>

    <!-- Scene 7: Final logo + CTA — Banas "Banas™ Start for free" moment -->
    <section class="scene scene-final" id="scene7">
      <!-- 8×4 grid of YAJA drama stills as scene bg. Each thumb POP-INs
           at its own delayed scroll moment — that's the Banas-style
           "バババっと" flurry where the grid assembles one tile at a
           time over a couple seconds of scroll. -->
      <div class="thumb-grid final-grid-thumbs" aria-hidden="true">
        {
          finalThumbsWithDelay.map(({ src, delay }) => (
            <div class="pop-thumb" data-delay={delay.toFixed(3)}>
              <img src={src} alt="" loading="lazy" />
            </div>
          ))
        }
      </div>

      <div class="final-center">
        <div class="final-lockup">
          <img src="/logos/fire-symbol/red-symbol.png" alt="" class="final-flame" />
          <span class="final-wordmark">YAJA<span class="tm">™</span></span>
        </div>
        <a href="mailto:info@yajacamp.com" class="final-cta">Start a project</a>
        <p class="final-foot">yajacamp.com</p>
      </div>
    </section>

  </div>
</div>

<!-- ===== Bottom progress bar ===== -->
<div class="progress" id="story-progress"></div>

<style is:global>
  /* ===== Fixed LED background video — always behind everything ===== */
  .story-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .story-bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.75;
  }
  .story-bg-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(30, 30, 30, 0.55) 0%,
      rgba(30, 30, 30, 0.25) 38%,
      rgba(30, 30, 30, 0.7) 100%
    );
  }

  /* ===== Huge blurred YAJA wordmark — Banas-style signature bg ===== */
  .story-mark {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    pointer-events: none;
  }
  .story-mark-text {
    font-family: var(--font-num);
    font-weight: 900;
    font-size: 48vw;
    letter-spacing: -0.08em;
    line-height: 1;
    color: rgba(255, 255, 255, 0.06);
    filter: blur(28px);
    transform: scaleY(0.85);
    white-space: nowrap;
    will-change: transform;
  }

  /* ===== Scene counter (top-right pill) ===== */
  .scene-counter {
    position: fixed;
    top: 80px;
    right: 24px;
    z-index: 50;
    padding: 8px 16px;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c8cdd7;
    backdrop-filter: blur(8px);
  }
  .scene-counter .red {
    color: var(--color-yaja-red);
  }

  /* ===== Story container & sticky stage ===== */
  .story {
    position: relative;
    height: 800vh; /* 8 scenes × 100vh */
    z-index: 2;
  }
  .story .stage {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }
  .story .scene {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 32px;
    opacity: 0;
    will-change: opacity, transform;
  }

  /* ----- Scene 0: Intro tagline ----- */
  .s0-tagline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(32px, 5vw, 84px);
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: #fff;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.5);
  }
  .s0-tagline .line {
    opacity: 0;
    transform: translate3d(0, 24px, 0);
    will-change: opacity, transform;
  }
  .s0-tagline .line:last-child::after {
    content: "";
    display: inline-block;
    width: 0.16em;
    height: 0.85em;
    margin-left: 0.14em;
    background: var(--color-yaja-red);
    vertical-align: -0.05em;
    transform: translateY(0.05em);
  }

  /* ----- scene-ad: Banas "single floating ad" moment ----- */
  .scene-ad {
    padding: 32px 5vw;
  }
  .ad-card {
    position: relative;
    width: min(540px, 80vw);
    aspect-ratio: 9 / 14;
    background: #0a0a0a;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 60px 120px -20px rgba(0, 0, 0, 0.85),
      0 30px 60px -15px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .ad-card video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
  }
  .ad-meta {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 36px 32px 32px;
    background: linear-gradient(
      180deg,
      transparent 40%,
      rgba(0, 0, 0, 0.85) 100%
    );
    text-align: left;
  }
  .ad-title {
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(32px, 4.5vw, 60px);
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: #fff;
    margin-bottom: 16px;
  }
  .ad-body {
    font-size: 13px;
    line-height: 1.55;
    color: #c8cdd7;
    margin-bottom: 24px;
  }
  .ad-body strong {
    color: #fff;
    font-weight: 700;
  }
  .ad-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .ad-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--color-yaja-red);
    color: #fff;
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 4px;
  }
  .ad-brand {
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9ca3af;
  }

  /* ----- scene-modal: Banas UI card moment ----- */
  .modal-card {
    width: min(640px, 88vw);
    padding: 22px 24px 20px;
    background: rgba(245, 245, 247, 0.96);
    color: #1e1e1e;
    border-radius: 14px;
    box-shadow:
      0 60px 120px -20px rgba(0, 0, 0, 0.85),
      0 24px 60px -15px rgba(0, 0, 0, 0.5);
    text-align: left;
  }
  .modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .modal-label {
    color: var(--color-yaja-red);
  }
  .modal-action {
    color: #6e7380;
  }
  .modal-input {
    font-size: clamp(14px, 1.3vw, 17px);
    color: #1e1e1e;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 16px;
  }
  .modal-progress {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }
  .modal-progress .bar {
    flex: 1;
    height: 3px;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    overflow: hidden;
  }
  .modal-progress .fill {
    display: block;
    width: 64%;
    height: 100%;
    background: linear-gradient(90deg, #1e1e1e 0%, #6e7380 100%);
  }
  .modal-meta {
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6e7380;
  }

  /* ----- scene-steps: Banas 3-step + poster grid ----- */
  .scene-steps {
    padding: 32px 4vw;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 6vw;
    width: 100%;
    max-width: 1280px;
    align-items: center;
  }
  .steps-left {
    text-align: left;
  }
  .steps-eyebrow {
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-yaja-red);
    margin-bottom: 32px;
  }
  .steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .step {
    display: flex;
    align-items: baseline;
    gap: 16px;
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(40px, 6vw, 96px);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: #fff;
  }
  .step-num {
    font-size: 0.32em;
    color: #6e7380;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .steps-foot {
    margin-top: 36px;
    max-width: 32ch;
    font-size: 14px;
    color: #c8cdd7;
    line-height: 1.6;
  }
  .steps-right {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    max-width: 540px;
  }
  .thumb {
    position: relative;
    aspect-ratio: 9 / 14;
    background: #111;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .thumb video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }
  .thumb-tag {
    position: absolute;
    bottom: 10px;
    left: 12px;
    font-family: var(--font-num);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }
  @media (max-width: 900px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .steps-right {
      grid-template-columns: repeat(2, 1fr);
      max-width: 360px;
      margin: 0 auto;
    }
  }

  /* ----- scene-stats: big numbers ----- */
  .stats-row {
    display: flex;
    gap: clamp(36px, 8vw, 120px);
    flex-wrap: wrap;
    justify-content: center;
  }
  .stat-cell {
    text-align: center;
  }
  .stat-val {
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(72px, 11vw, 180px);
    line-height: 0.95;
    letter-spacing: -0.045em;
    color: #fff;
  }
  .stat-val .u {
    font-size: 0.32em;
    color: #9ca3af;
    margin-left: 8px;
    font-weight: 700;
  }
  .stat-label {
    margin-top: 16px;
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c8cdd7;
  }
  .stats-tag {
    margin-top: 64px;
    font-family: var(--font-num);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-yaja-red);
  }

  /* ----- scene-slogan: Banas "No designer needed" moment ----- */
  .slogan {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(48px, 9vw, 156px);
    letter-spacing: -0.045em;
    line-height: 0.96;
    color: #fff;
    text-align: left;
  }
  .slogan .line {
    opacity: 0;
    transform: translate3d(0, 32px, 0);
    will-change: opacity, transform;
  }
  .slogan .line:last-child {
    color: var(--color-yaja-red);
  }
  .slogan-sub {
    margin-top: 32px;
    max-width: 42ch;
    font-size: 14px;
    color: #c8cdd7;
    line-height: 1.6;
    text-align: left;
  }

  /* ----- scene-final: huge wordmark + CTA + grid bg ----- */
  .scene-final {
    padding: 0;
  }

  /* ===== Stagger pop-in thumb grid (Banas "バババっと" flurry) =====
     Each .pop-thumb gets a data-delay (0..1). The script reads scroll
     progress and per-thumb interpolates opacity + scale + blur from
     "not yet" → "fully landed". When many thumbs share a scroll window
     with random delays, the eye sees them pop in one after another. */
  .thumb-grid {
    display: grid;
    gap: 8px;
  }
  .pop-thumb {
    aspect-ratio: 9 / 14;
    border-radius: 6px;
    overflow: hidden;
    background: #111;
    opacity: 0;
    transform: scale(1.35);
    filter: blur(8px);
    will-change: opacity, transform, filter;
  }
  .pop-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* steps scene — 4×2 grid on the right column */
  .steps-grid-thumbs {
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 1fr);
    max-width: 540px;
  }

  /* final scene — 8×4 grid filling the full stage as bg */
  .final-grid-thumbs {
    position: absolute;
    inset: 16px;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(4, 1fr);
    opacity: 0.55;
    z-index: 1;
  }
  .final-grid-thumbs .pop-thumb {
    border-radius: 5px;
  }

  /* Respect reduced motion — show static at full state */
  @media (prefers-reduced-motion: reduce) {
    .pop-thumb {
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }
  }
  .final-center {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: radial-gradient(
      ellipse at center,
      rgba(30, 30, 30, 0.85) 0%,
      rgba(30, 30, 30, 0.55) 50%,
      transparent 100%
    );
    padding: 64px 96px;
    border-radius: 24px;
  }
  .final-lockup {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .final-flame {
    width: clamp(40px, 5vw, 64px);
    filter: drop-shadow(0 0 20px rgba(255, 72, 72, 0.5));
  }
  .final-wordmark {
    font-family: var(--font-num);
    font-weight: 900;
    font-size: clamp(72px, 10vw, 144px);
    letter-spacing: -0.05em;
    line-height: 1;
    color: #fff;
    display: inline-flex;
    align-items: baseline;
  }
  .final-wordmark .tm {
    font-size: 0.24em;
    color: #c8cdd7;
    margin-left: 0.04em;
    transform: translateY(-0.7em);
    font-weight: 700;
    letter-spacing: 0;
  }
  .final-cta {
    margin-top: 32px;
    padding: 16px 36px;
    background: #fff;
    color: #1e1e1e;
    font-family: var(--font-num);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .final-cta:hover {
    transform: translateY(-2px);
  }
  .final-foot {
    margin-top: 22px;
    font-family: var(--font-num);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #6e7380;
  }

  /* ----- Progress bar ----- */
  .story #story-progress,
  .progress {
    position: fixed;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--color-yaja-red);
    z-index: 60;
    transition: width 0.08s linear;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ===== Scene cross-fade — single ScrollTrigger drives all 8 scenes
  // The Banas reference packs 8 distinct moments into ~22s of video; we
  // give each a roughly equal slice of 800vh of scroll progress.

  interface SceneSpec {
    sel: string;
    label: string;
    fadeIn: number;
    holdStart: number;
    holdEnd: number;
    fadeOut: number;
    el?: HTMLElement | null;
  }

  // Eight scenes evenly spread across [0, 1] with ~12% each, plus
  // 2-3% transition buffer between holds.
  const sceneSpecs: SceneSpec[] = [
    {
      sel: "#scene0",
      label: "01 / 08 — Intro",
      fadeIn: -Infinity,
      holdStart: 0,
      holdEnd: 0.08,
      fadeOut: 0.13,
    },
    {
      sel: "#scene1",
      label: "02 / 08 — Project: Vaseline",
      fadeIn: 0.14,
      holdStart: 0.17,
      holdEnd: 0.23,
      fadeOut: 0.27,
    },
    {
      sel: "#scene2",
      label: "03 / 08 — Service",
      fadeIn: 0.28,
      holdStart: 0.3,
      holdEnd: 0.35,
      fadeOut: 0.4,
    },
    {
      sel: "#scene3",
      label: "04 / 08 — Project: Samsung",
      fadeIn: 0.41,
      holdStart: 0.44,
      holdEnd: 0.5,
      fadeOut: 0.54,
    },
    {
      sel: "#scene4",
      label: "05 / 08 — Process",
      fadeIn: 0.55,
      holdStart: 0.58,
      holdEnd: 0.65,
      fadeOut: 0.7,
    },
    {
      sel: "#scene5",
      label: "06 / 08 — Numbers",
      fadeIn: 0.71,
      holdStart: 0.74,
      holdEnd: 0.79,
      fadeOut: 0.83,
    },
    {
      sel: "#scene6",
      label: "07 / 08 — Slogan",
      fadeIn: 0.84,
      holdStart: 0.86,
      holdEnd: 0.9,
      fadeOut: 0.93,
    },
    {
      sel: "#scene7",
      label: "08 / 08 — YAJA",
      fadeIn: 0.94,
      holdStart: 0.96,
      holdEnd: Infinity,
      fadeOut: Infinity,
    },
  ];

  sceneSpecs.forEach((s) => {
    s.el = document.querySelector<HTMLElement>(s.sel);
  });

  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
  const clamp01 = (x: number) => Math.max(0, Math.min(1, x));
  const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
  const easeInCubic = (t: number) => t * t * t;

  const ENTER_Y = 80; // px
  const EXIT_Y = -60;

  function computeSceneState(p: number, s: SceneSpec) {
    if (p < s.fadeIn) return { opacity: 0, y: ENTER_Y, scale: 1.02 };
    if (p < s.holdStart) {
      const raw = clamp01((p - s.fadeIn) / (s.holdStart - s.fadeIn));
      const t = easeOutCubic(raw);
      return { opacity: t, y: lerp(ENTER_Y, 0, t), scale: lerp(1.02, 1, t) };
    }
    if (p <= s.holdEnd) return { opacity: 1, y: 0, scale: 1 };
    if (p <= s.fadeOut) {
      const raw = clamp01((p - s.holdEnd) / (s.fadeOut - s.holdEnd));
      const t = easeInCubic(raw);
      return { opacity: 1 - t, y: lerp(0, EXIT_Y, t), scale: lerp(1, 0.98, t) };
    }
    return { opacity: 0, y: EXIT_Y, scale: 0.98 };
  }

  sceneSpecs.forEach((s, i) => {
    if (!s.el) return;
    if (i === 0) {
      gsap.set(s.el, { opacity: 1, y: 0, scale: 1 });
    } else {
      gsap.set(s.el, { opacity: 0, y: ENTER_Y, scale: 1.02 });
    }
  });

  // Background wordmark drifts upward subtly with scroll for parallax.
  const mark = document.querySelector<HTMLElement>(".story-mark-text");

  ScrollTrigger.create({
    trigger: ".story",
    start: "top top",
    end: "bottom bottom",
    scrub: true,
    onUpdate: (self) => {
      const p = self.progress;
      sceneSpecs.forEach((s) => {
        if (!s.el) return;
        const { opacity, y, scale } = computeSceneState(p, s);
        s.el.style.opacity = String(opacity);
        s.el.style.transform = `translate3d(0, ${y}px, 0) scale(${scale})`;
      });
      applyIntroLines(p);
      applySloganLines(p);
      applyPopThumbs(p);
      if (mark) {
        // Drift -40px → +40px across full scroll, slight scale.
        const dy = (p - 0.5) * 80;
        const sc = 0.85 + p * 0.15;
        mark.style.transform = `scaleY(0.85) translate3d(0, ${dy}px, 0) scale(${sc})`;
      }
    },
  });

  // ===== Intro tagline line stagger =====
  const introLines = Array.from(
    document.querySelectorAll<HTMLElement>(".s0-tagline .line")
  );
  const INTRO_STARTS = [-0.04, 0.02, 0.05];
  const INTRO_DUR = 0.04;
  function applyIntroLines(p: number) {
    introLines.forEach((el, i) => {
      const start = INTRO_STARTS[i] ?? 0;
      const raw = clamp01((p - start) / INTRO_DUR);
      const t = easeOutCubic(raw);
      el.style.opacity = String(t);
      el.style.transform = `translate3d(0, ${(1 - t) * 24}px, 0)`;
    });
  }
  applyIntroLines(0);

  // ===== Pop-thumb stagger entrance (Banas "バババっと" effect) =====
  // Two groups of thumbs land in two different scroll windows:
  //   • steps group   — appears while scene-steps is on screen
  //                     (scene fadeIn 0.55 → holdEnd 0.65). We map
  //                     thumb delays (0..1) across 0.55 → 0.66.
  //   • final group   — assembles as user enters the final scene.
  //                     Window: 0.82 → 0.97 so they're mostly placed
  //                     by the time the YAJA™ lockup is centered.
  // Each thumb's window is 0.04 wide (~3% of total scroll) so popping
  // feels punchy not slow.
  interface PopGroup {
    nodes: NodeListOf<HTMLElement>;
    start: number;
    end: number;
  }
  const POP_DURATION = 0.04;
  const popGroups: PopGroup[] = [
    {
      nodes: document.querySelectorAll<HTMLElement>(
        ".steps-grid-thumbs .pop-thumb",
      ),
      start: 0.55,
      end: 0.66,
    },
    {
      nodes: document.querySelectorAll<HTMLElement>(
        ".final-grid-thumbs .pop-thumb",
      ),
      start: 0.82,
      end: 0.97,
    },
  ];

  function applyPopThumbs(p: number) {
    popGroups.forEach((g) => {
      g.nodes.forEach((el) => {
        const delay = parseFloat(el.dataset.delay ?? "0");
        const triggerStart = g.start + delay * (g.end - g.start);
        const raw = clamp01((p - triggerStart) / POP_DURATION);
        const t = easeOutCubic(raw);
        el.style.opacity = String(t);
        el.style.transform = `scale(${lerp(1.35, 1, t)})`;
        el.style.filter = `blur(${lerp(8, 0, t)}px)`;
      });
    });
  }
  applyPopThumbs(0);

  // ===== Slogan line stagger (Scene 7, fadeIn at 0.84) =====
  const sloganLines = Array.from(
    document.querySelectorAll<HTMLElement>(".slogan .line")
  );
  const SLOGAN_STARTS = [0.85, 0.865, 0.88];
  const SLOGAN_DUR = 0.025;
  function applySloganLines(p: number) {
    sloganLines.forEach((el, i) => {
      const start = SLOGAN_STARTS[i] ?? 0;
      const raw = clamp01((p - start) / SLOGAN_DUR);
      const t = easeOutCubic(raw);
      el.style.opacity = String(t);
      el.style.transform = `translate3d(0, ${(1 - t) * 32}px, 0)`;
    });
  }
  applySloganLines(0);

  // ===== Number count-up — fires when Stats scene fades in =====
  const nums = document.querySelectorAll<HTMLElement>(".scene-stats .num");
  const NUM_FIRE = 0.73; // fadeIn at 0.71, fire just after
  const NUM_RESET = 0.68;
  let numsTriggered = false;
  ScrollTrigger.create({
    trigger: ".story",
    start: "top top",
    end: "bottom bottom",
    onUpdate: (self) => {
      if (self.progress >= NUM_FIRE && !numsTriggered) {
        numsTriggered = true;
        nums.forEach((el) => {
          const target = parseInt(el.dataset.target ?? "0", 10);
          const obj = { v: 0 };
          gsap.to(obj, {
            v: target,
            duration: 1.4,
            ease: "power2.out",
            onUpdate: () => (el.textContent = String(Math.round(obj.v))),
          });
        });
      }
      if (self.progress < NUM_RESET) {
        numsTriggered = false;
        nums.forEach((el) => (el.textContent = "0"));
      }
    },
  });

  // ===== Progress bar + scene counter =====
  const counter = document.getElementById("scene-counter");
  const progress = document.getElementById("story-progress");
  ScrollTrigger.create({
    trigger: ".story",
    start: "top top",
    end: "bottom bottom",
    onUpdate: (self) => {
      if (progress) progress.style.width = `${(self.progress * 100).toFixed(1)}%`;
      let active = sceneSpecs[0];
      for (const s of sceneSpecs) {
        if (self.progress >= s.holdStart) active = s;
      }
      if (counter) {
        const [num, ...rest] = active.label.split(" ");
        counter.innerHTML = `<span class="red">${num}</span> ${rest.join(" ")}`;
      }
    },
  });
</script>
