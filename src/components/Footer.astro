---
import { site } from "@/lib/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-yaja-dark py-14">
  <div class="mx-auto max-w-[1440px] px-6 md:px-10">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="flex items-center gap-3">
        <img
          src="/logos/fire-symbol/red-symbol.png"
          alt="YAJA"
          width="40"
          height="40"
          class="h-9 w-auto"
        />
        <div>
          <p class="font-num text-base font-extrabold tracking-tight">
            YAJA Inc.
          </p>
          <p class="text-sm text-yaja-gray-mid">{site.description}</p>
        </div>
      </div>

      <div class="grid gap-8 sm:grid-cols-3">
        <div>
          <p
            class="font-num text-[11px] font-semibold uppercase tracking-[0.12em] text-yaja-gray"
          >
            Studio
          </p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a class="hover:text-yaja-red" href="#about">About</a></li>
            <li><a class="hover:text-yaja-red" href="#works">Works</a></li>
            <li><a class="hover:text-yaja-red" href="#services">Services</a></li>
          </ul>
        </div>

        <div>
          <p
            class="font-num text-[11px] font-semibold uppercase tracking-[0.12em] text-yaja-gray"
          >
            Channels
          </p>
          <ul class="mt-3 space-y-2 text-sm">
            <li>
              <a
                class="hover:text-yaja-red"
                href="https://www.tiktok.com/@yajacamp"
                target="_blank"
                rel="noopener"
              >
                @yajacamp
              </a>
            </li>
            <li>
              <a
                class="hover:text-yaja-red"
                href="https://www.tiktok.com/@ycn_videographer"
                target="_blank"
                rel="noopener"
              >
                @ycn_videographer
              </a>
            </li>
          </ul>
        </div>

        <div>
          <p
            class="font-num text-[11px] font-semibold uppercase tracking-[0.12em] text-yaja-gray"
          >
            Contact
          </p>
          <ul class="mt-3 space-y-2 text-sm">
            <li>
              <a class="hover:text-yaja-red" href={`mailto:${site.email}`}>
                {site.email}
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-white/5 pt-6 text-xs text-yaja-gray-mid sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} YAJA Inc. All rights reserved.</p>
      <p class="font-num tracking-[0.08em]">대한민국 No.1 숏폼 드라마 스튜디오</p>
    </div>
  </div>
</footer>
