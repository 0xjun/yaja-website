---
import { site } from "@/lib/site";
const year = new Date().getFullYear();

/**
 * Footer — full sitemap matching OASIZ's bottom-of-page pattern.
 */
const sitemap = [
  {
    title: "Sitemap",
    items: [
      { label: "Home", href: "/" },
      { label: "About", href: "/about" },
      { label: "Projects", href: "/projects" },
      { label: "Column", href: "/column" },
      { label: "News", href: "/news" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Channels",
    items: [
      { label: "@yajacamp", href: "https://www.tiktok.com/@yajacamp", external: true },
      { label: "@ycn_videographer", href: "https://www.tiktok.com/@ycn_videographer", external: true },
    ],
  },
  {
    title: "Contact",
    items: [
      { label: site.email, href: `mailto:${site.email}` },
      { label: site.address, href: null },
    ],
  },
];
---

<footer class="border-t border-white/8 bg-yaja-dark py-16 md:py-20">
  <div class="mx-auto max-w-[1280px] px-6 md:px-10">
    <div class="grid gap-12 md:grid-cols-[1fr_auto] md:items-start md:gap-20">
      <!-- Brand column -->
      <div>
        <a href="/" class="inline-flex items-center gap-3">
          <img
            src="/logos/fire-symbol/red-symbol.png"
            alt="YAJA"
            width="48"
            height="48"
            class="h-10 w-auto"
          />
          <p class="font-num text-base font-extrabold tracking-tight">
            YAJA Inc.
          </p>
        </a>
        <p class="mt-5 max-w-[40ch] text-sm text-yaja-gray-mid md:text-base">
          {site.description}
        </p>
        <p class="font-num mt-2 text-[11px] uppercase tracking-[0.18em] text-yaja-gray">
          {site.tagline}
        </p>
      </div>

      <!-- Sitemap columns -->
      <div class="grid gap-10 sm:grid-cols-3 md:gap-16">
        {
          sitemap.map((col) => (
            <div>
              <p class="font-num text-[10px] font-semibold uppercase tracking-[0.18em] text-yaja-red">
                {col.title}
              </p>
              <ul class="mt-4 space-y-2.5 text-sm">
                {col.items.map((item) =>
                  item.href ? (
                    <li>
                      <a
                        href={item.href}
                        target={item.external ? "_blank" : undefined}
                        rel={item.external ? "noopener" : undefined}
                        class="font-num text-yaja-white/80 transition-colors hover:text-yaja-red"
                      >
                        {item.label}
                      </a>
                    </li>
                  ) : (
                    <li class="font-num text-yaja-gray">{item.label}</li>
                  ),
                )}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="mt-16 flex flex-col gap-3 border-t border-white/8 pt-6 text-xs text-yaja-gray-mid sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="font-num tracking-[0.06em]">
        © {year} YAJA Inc. All rights reserved.
      </p>
      <p class="font-num tracking-[0.18em] uppercase">
        K-Short Drama Studio · Est. 2024
      </p>
    </div>
  </div>
</footer>
