---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PageHero from "@/components/PageHero.astro";
import { column } from "@/lib/site";
---

<Layout
  title="COLUMN — YAJA Inc."
  description="숏폼 드라마 시장과 디지털 콘텐츠 산업에 대한 인사이트 칼럼."
>
  <Header />
  <main>
    <PageHero
      eyebrow="Column"
      title="업계"
      accent="인사이트"
      subtitle="숏폼 드라마 시장의 흐름과 데이터를 정기적으로 정리합니다."
    />

    <section class="bg-yaja-dark py-16 md:py-24">
      <div class="mx-auto max-w-[1280px] px-6 md:px-10">
        <ul class="reveal reveal-stagger grid gap-px overflow-hidden rounded-lg border border-white/10 bg-white/10 md:grid-cols-2">
          {
            column.map((c) => (
              <li>
                <a
                  href={c.href}
                  class="group flex flex-col gap-6 bg-yaja-dark p-8 transition-colors hover:bg-yaja-charcoal md:p-10"
                >
                  <div class="aspect-[16/10] overflow-hidden rounded bg-gradient-to-br from-yaja-charcoal to-black ring-1 ring-white/5">
                    <div class="flex h-full w-full items-center justify-center">
                      <img
                        src="/logos/fire-symbol/red-symbol.png"
                        alt=""
                        class="h-1/3 w-auto opacity-30"
                      />
                    </div>
                  </div>

                  <div>
                    <p class="font-num text-[11px] font-semibold uppercase tracking-[0.18em] text-yaja-red">
                      {c.category} · {c.date}
                    </p>
                    <p class="mt-3 text-xl font-bold leading-snug transition-colors group-hover:text-yaja-red md:text-2xl">
                      {c.title}
                    </p>
                  </div>
                </a>
              </li>
            ))
          }

          <!-- Coming-soon placeholder for visual balance -->
          <li class="bg-yaja-dark p-8 md:p-10">
            <div class="aspect-[16/10] overflow-hidden rounded bg-gradient-to-br from-yaja-charcoal/50 to-black/50 ring-1 ring-dashed ring-white/10">
              <div class="flex h-full w-full items-center justify-center">
                <span
                  class="font-num text-[10px] uppercase tracking-[0.22em] text-yaja-gray-mid"
                >
                  Coming soon
                </span>
              </div>
            </div>
            <p class="font-num mt-6 text-[11px] uppercase tracking-[0.18em] text-yaja-gray-mid">
              새 콘텐츠를 준비 중입니다
            </p>
          </li>
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
