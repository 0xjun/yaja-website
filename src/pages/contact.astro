---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PageHero from "@/components/PageHero.astro";
import { site } from "@/lib/site";
---

<Layout
  title="CONTACT — YAJA Inc."
  description="YAJA Inc.에 협업 · 채용 · 미디어 문의를 보내실 수 있습니다."
>
  <Header />
  <main>
    <PageHero
      eyebrow="Contact"
      title="함께 만들어"
      accent="갑시다"
      subtitle="브랜드 캠페인 · 채용 · 미디어 문의 모두 환영합니다. 영업일 1일 이내에 답신드립니다."
    />

    <section class="bg-yaja-dark py-16 md:py-24">
      <div class="mx-auto max-w-[1280px] px-6 md:px-10">
        <div class="reveal grid gap-12 md:grid-cols-2 md:gap-20">
          <!-- Contact details -->
          <div>
            <p class="font-num text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red">
              직접 연락
            </p>

            <ul class="mt-8 space-y-8">
              <li>
                <p class="font-num text-[11px] uppercase tracking-[0.18em] text-yaja-gray-mid">
                  Email
                </p>
                <a
                  href={`mailto:${site.email}`}
                  class="font-num mt-2 block text-2xl font-bold tracking-tight transition-colors hover:text-yaja-red md:text-3xl"
                >
                  {site.email}
                </a>
              </li>

              <li>
                <p class="font-num text-[11px] uppercase tracking-[0.18em] text-yaja-gray-mid">
                  Channels
                </p>
                <div class="mt-2 flex flex-col gap-1">
                  <a
                    href="https://www.tiktok.com/@yajacamp"
                    target="_blank"
                    rel="noopener"
                    class="font-num text-base font-medium transition-colors hover:text-yaja-red md:text-lg"
                  >
                    @yajacamp
                  </a>
                  <a
                    href="https://www.tiktok.com/@ycn_videographer"
                    target="_blank"
                    rel="noopener"
                    class="font-num text-base font-medium transition-colors hover:text-yaja-red md:text-lg"
                  >
                    @ycn_videographer
                  </a>
                </div>
              </li>

              <li>
                <p class="font-num text-[11px] uppercase tracking-[0.18em] text-yaja-gray-mid">
                  Address
                </p>
                <p class="mt-2 text-base text-yaja-gray md:text-lg">
                  {site.address}
                </p>
              </li>
            </ul>
          </div>

          <!-- Inquiry types -->
          <div>
            <p class="font-num text-[11px] font-semibold uppercase tracking-[0.32em] text-yaja-red">
              문의 종류
            </p>

            <ul class="mt-8 space-y-3">
              {
                [
                  { tag: "Business", text: "브랜드 캠페인 · PPL · 광고 협업" },
                  { tag: "Recruit", text: "디렉터 · PD · 마케터 채용" },
                  { tag: "Media", text: "취재 · 인터뷰 · 행사 협찬" },
                  { tag: "Partnership", text: "콘텐츠 · IP 라이선스 협업" },
                ].map((item) => (
                  <li class="rounded-md border border-white/10 bg-white/[0.02] p-5 transition-colors hover:border-yaja-red/40">
                    <span class="font-num text-[10px] font-semibold uppercase tracking-[0.18em] text-yaja-red">
                      {item.tag}
                    </span>
                    <p class="mt-1 text-base text-yaja-white md:text-lg">
                      {item.text}
                    </p>
                  </li>
                ))
              }
            </ul>

            <a
              href={`mailto:${site.email}?subject=YAJA%20Inquiry`}
              class="font-num mt-10 inline-flex w-full items-center justify-center gap-2 rounded-md bg-yaja-red px-8 py-5 text-sm font-bold tracking-[0.18em] text-yaja-white transition-transform hover:-translate-y-0.5 md:w-auto"
            >
              메일 보내기
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
