---
/**
 * Home page — Banas-style scroll-pinned 5-scene story.
 *
 * The LED-screen background loop stays pinned behind everything while
 * the user scrolls; five scenes cross-fade in/out as scroll progress
 * advances:
 *
 *   01 Brand → 02 Featured Campaign → 03 Numbers
 *      → 04 On Air → 05 Contact CTA
 *
 * All five scenes (plus the fixed bg video, scene counter, and progress
 * bar) live inside `<StoryScroll />`. Other component sections
 * (Strategy / Categories / Clients / Partnership / Column / News) are
 * intentionally not rendered here — they'll move to dedicated routes
 * (/about, /works, /column, /news) so the homepage stays a single
 * cinematic scroll.
 */
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import StoryScroll from "@/components/StoryScroll.astro";
---

<Layout>
  <Header />
  <main>
    <StoryScroll />
  </main>
  <Footer />
</Layout>
